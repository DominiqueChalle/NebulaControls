<nebula:NebulaWindow x:Class="NebulaControls.Demo.MainWindow"
                     xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                     xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                     xmlns:nebula="clr-namespace:NebulaControls.Controls;assembly=NebulaControls"
                     mc:Ignorable="d"
                     Title="NebulaControls"
                     Subtitle="Professional WPF control gallery"
                     IconContent="N"
                     Style="{StaticResource NebulaWindow}"
                     MinWidth="980"
                     MinHeight="680">

    <nebula:NebulaWindow.TitleBarContent>
        <Border Background="{DynamicResource Brush.Background}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14,7"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8"
                         Height="8"
                         Fill="{DynamicResource Brush.Success}"
                         Margin="0,0,8,0"
                         VerticalAlignment="Center"/>
                <TextBlock x:Name="ActiveThemeStatusText"
                           Text="NebulaDarkPurple theme active"
                           Style="{StaticResource Typography.TextBlock.Caption}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </nebula:NebulaWindow.TitleBarContent>

    <nebula:NebulaWindow.Resources>
        <Style x:Key="DemoSidebarButton"
               BasedOn="{StaticResource NebulaGhostButton}"
               TargetType="Button">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="14,9"/>
        </Style>

    </nebula:NebulaWindow.Resources>

    <Grid>
        <DockPanel>
            <Menu DockPanel.Dock="Top"
                  Style="{StaticResource NebulaWindowMenu}">
                <MenuItem Header="File">
                    <MenuItem Header="New item"/>
                    <MenuItem Header="Open"/>
                    <Separator Style="{StaticResource NebulaMenuSeparator}"/>
                    <MenuItem Header="Exit"
                              Click="ExitMenuItem_Click"/>
                </MenuItem>
                <MenuItem Header="Edit">
                    <MenuItem Header="Undo"/>
                    <MenuItem Header="Redo"/>
                </MenuItem>
                <MenuItem Header="View">
                    <MenuItem Header="Controls"/>
                    <MenuItem Header="Inputs"/>
                    <MenuItem Header="Data"/>
                    <MenuItem Header="More">
                        <MenuItem Header="Status bar"/>
                        <MenuItem Header="Diagnostics"/>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="Paramètre">
                    <MenuItem Header="Theme">
                        <MenuItem Header="NebulaDarkPurple"
                                  Click="ApplyDarkPurpleThemeMenuItem_Click"/>
                        <MenuItem Header="NebulaDarkBlue"
                                  Click="ApplyDarkBlueThemeMenuItem_Click"/>
                        <MenuItem Header="NebulaLightPurple"
                                  Click="ApplyLightPurpleThemeMenuItem_Click"/>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="Help">
                    <MenuItem Header="About NebulaControls"/>
                </MenuItem>
            </Menu>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarColumn" Width="244"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="SidebarPanel"
                        Background="{DynamicResource Brush.Surface}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="0,0,1,0"
                        Padding="24,20,18,24">
                    <StackPanel>
                        <Grid>
                            <TextBlock x:Name="SidebarTitleText"
                                       Text="Gallery"
                                       Style="{StaticResource DemoSectionTitle}"
                                       VerticalAlignment="Center"/>
                            <Button x:Name="SidebarToggleButton"
                                    Content="&lt;"
                                    Style="{StaticResource NebulaWindowButton}"
                                    Width="34"
                                    Height="30"
                                    Padding="0"
                                    HorizontalAlignment="Right"
                                    Click="SidebarToggleButton_Click"/>
                        </Grid>
                        <TextBlock x:Name="SidebarDescriptionText"
                                   Text="Browse the current NebulaControls surface and component states."
                                   Style="{StaticResource Typography.TextBlock.Secondary}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,24"/>
                        <Button x:Name="ActionsNavButton"
                                Content="Buttons + Feedback"
                                Style="{StaticResource DemoSidebarButton}"
                                Click="ActionsNavButton_Click"/>
                        <Button x:Name="InputsNavButton"
                                Content="Inputs + Progress"
                                Style="{StaticResource DemoSidebarButton}"
                                Click="InputsNavButton_Click"/>
                        <Button x:Name="CollectionsNavButton"
                                Content="Collections + Data"
                                Style="{StaticResource DemoSidebarButton}"
                                Click="CollectionsNavButton_Click"/>
                        <Button x:Name="PickerLabNavButton"
                                Content="Picker Lab"
                                Style="{StaticResource DemoSidebarButton}"
                                Click="PickerLabNavButton_Click"/>
                        <Button x:Name="ContainersNavButton"
                                Content="Containers + Layout"
                                Style="{StaticResource DemoSidebarButton}"
                                Click="ContainersNavButton_Click"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Column="1"
                      Margin="28,22,26,26">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                                <TextBlock Text="Control Gallery"
                                           Style="{StaticResource Typography.TextBlock.PageTitle}"/>
                                <TextBlock Text="A focused preview surface for NebulaControls components, interaction states, and theme resources."
                                           Style="{StaticResource Typography.TextBlock.Secondary}"
                                           TextWrapping="Wrap"
                                           Margin="0,8,24,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Top">
                            <nebula:NebulaBadge Style="{StaticResource NebulaInfoBadge}"
                                                Content="WPF"
                                                Margin="0,0,10,0"/>
                            <nebula:NebulaBadge Style="{StaticResource NebulaPurpleBadge}"
                                                Content="Nebula"/>
                        </StackPanel>
                    </Grid>

                    <ContentControl x:Name="DemoContentHost"
                                    Grid.Row="1"
                                    Margin="0,28,0,0"/>
                </Grid>
            </Grid>
            </DockPanel>

        <nebula:NebulaToast x:Name="GlobalToast"
                            Style="{StaticResource NebulaInfoToast}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Margin="0,0,28,28"
                            Opacity="0"
                            Visibility="Collapsed"
                            CloseClicked="GlobalToast_CloseClicked">
            <nebula:NebulaToast.RenderTransform>
                <TranslateTransform Y="34"/>
            </nebula:NebulaToast.RenderTransform>
        </nebula:NebulaToast>
    </Grid>
</nebula:NebulaWindow>

