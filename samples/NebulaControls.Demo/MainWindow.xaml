<Window x:Class="NebulaControls.Demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:nebula="clr-namespace:NebulaControls.Controls;assembly=NebulaControls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="NebulaControls External Demo"
        MinWidth="980"
        MinHeight="680"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource Brush.Background}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="DemoWindowButton" TargetType="Button">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Brush.SurfaceHover}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Brush.SurfaceActive}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DemoSidebarButton"
               BasedOn="{StaticResource NebulaGhostButton}"
               TargetType="Button">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="14,9"/>
        </Style>

    </Window.Resources>

    <Border x:Name="DemoWindowFrame"
            Background="{DynamicResource Brush.Background}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="10">
        <DockPanel>
            <Grid DockPanel.Dock="Top"
                  Height="44"
                  Background="{DynamicResource Brush.Surface}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="18,0,0,0">
                    <Border Width="30"
                            Height="30"
                            Background="{DynamicResource Brush.SurfaceActive}"
                            BorderBrush="{DynamicResource Brush.BrandSoft}"
                            BorderThickness="1"
                            CornerRadius="7"
                            Margin="0,0,12,0">
                        <TextBlock Text="N"
                                   Foreground="{DynamicResource Brush.BrandSoft}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="NebulaControls"
                               Foreground="{DynamicResource Brush.TextPrimary}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Professional WPF control gallery"
                               Foreground="{DynamicResource Brush.TextMuted}"
                               FontSize="11"
                               Margin="0,1,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="{DynamicResource Brush.Background}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14,7"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8"
                                 Height="8"
                                 Fill="{DynamicResource Brush.Success}"
                                 Margin="0,0,8,0"
                                 VerticalAlignment="Center"/>
                        <TextBlock x:Name="ActiveThemeStatusText"
                                   Text="NebulaDarkPurple theme active"
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0">
                    <Button Content="_"
                            Style="{StaticResource DemoWindowButton}"
                            Click="MinimizeWindowButton_Click"/>
                    <Button Content="[]"
                            Style="{StaticResource DemoWindowButton}"
                            Click="MaximizeWindowButton_Click"/>
                    <Button Content="X"
                            Style="{StaticResource DemoWindowButton}"
                            Click="CloseWindowButton_Click"/>
                </StackPanel>
            </Grid>

            <Menu DockPanel.Dock="Top"
                  Style="{StaticResource NebulaWindowMenu}">
                <MenuItem Header="File">
                    <MenuItem Header="New item"/>
                    <MenuItem Header="Open"/>
                    <Separator Style="{StaticResource NebulaMenuSeparator}"/>
                    <MenuItem Header="Exit"
                              Click="ExitMenuItem_Click"/>
                </MenuItem>
                <MenuItem Header="Edit">
                    <MenuItem Header="Undo"/>
                    <MenuItem Header="Redo"/>
                </MenuItem>
                <MenuItem Header="View">
                    <MenuItem Header="Controls"/>
                    <MenuItem Header="Inputs"/>
                    <MenuItem Header="Data"/>
                    <MenuItem Header="More">
                        <MenuItem Header="Status bar"/>
                        <MenuItem Header="Diagnostics"/>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="Paramètre">
                    <MenuItem Header="Theme">
                        <MenuItem Header="NebulaDarkPurple"
                                  Click="ApplyDarkPurpleThemeMenuItem_Click"/>
                        <MenuItem Header="NebulaDarkBlue"
                                  Click="ApplyDarkBlueThemeMenuItem_Click"/>
                        <MenuItem Header="NebulaLightPurple"
                                  Click="ApplyLightPurpleThemeMenuItem_Click"/>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="Help">
                    <MenuItem Header="About NebulaControls"/>
                </MenuItem>
            </Menu>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarColumn" Width="244"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="SidebarPanel"
                        Background="{DynamicResource Brush.Surface}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="0,0,1,0"
                        Padding="24,20,18,24">
                    <StackPanel>
                        <Grid>
                            <TextBlock x:Name="SidebarTitleText"
                                       Text="Gallery"
                                       Style="{StaticResource DemoSectionTitle}"
                                       VerticalAlignment="Center"/>
                            <Button x:Name="SidebarToggleButton"
                                    Content="&lt;"
                                    Style="{StaticResource DemoWindowButton}"
                                    Width="34"
                                    Height="30"
                                    Padding="0"
                                    HorizontalAlignment="Right"
                                    Click="SidebarToggleButton_Click"/>
                        </Grid>
                        <TextBlock x:Name="SidebarDescriptionText"
                                   Text="Browse the current NebulaControls surface and component states."
                                   Foreground="{DynamicResource Brush.TextSecondary}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,24"/>
                        <Button x:Name="ActionsNavButton"
                                Content="Buttons + Feedback"
                                Style="{StaticResource DemoSidebarButton}"
                                Click="ActionsNavButton_Click"/>
                        <Button x:Name="InputsNavButton"
                                Content="Inputs + Progress"
                                Style="{StaticResource DemoSidebarButton}"
                                Click="InputsNavButton_Click"/>
                        <Button x:Name="CollectionsNavButton"
                                Content="Collections + Data"
                                Style="{StaticResource DemoSidebarButton}"
                                Click="CollectionsNavButton_Click"/>
                        <Button x:Name="ContainersNavButton"
                                Content="Containers + Layout"
                                Style="{StaticResource DemoSidebarButton}"
                                Click="ContainersNavButton_Click"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Column="1"
                      Margin="28,22,26,26">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Control Gallery"
                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                       FontSize="26"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="A focused preview surface for NebulaControls components, interaction states, and theme resources."
                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                       TextWrapping="Wrap"
                                       Margin="0,8,24,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Top">
                            <nebula:NebulaBadge Style="{StaticResource NebulaInfoBadge}"
                                                Content="WPF"
                                                Margin="0,0,10,0"/>
                            <nebula:NebulaBadge Style="{StaticResource NebulaPurpleBadge}"
                                                Content="Nebula"/>
                        </StackPanel>
                    </Grid>

                    <ContentControl x:Name="DemoContentHost"
                                    Grid.Row="1"
                                    Margin="0,28,0,0"/>
                </Grid>
            </Grid>
        </DockPanel>
    </Border>
</Window>

