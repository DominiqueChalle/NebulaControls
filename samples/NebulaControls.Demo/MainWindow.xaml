<nebula:NebulaWindow x:Class="NebulaControls.Demo.MainWindow"
                     xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                     xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                     xmlns:nebula="clr-namespace:NebulaControls.Controls;assembly=NebulaControls"
                     mc:Ignorable="d"
                     Title="NebulaControls"
                     Subtitle="Professional WPF control gallery"
                     IconContent="N"
                     Style="{StaticResource NebulaWindow}"
                     MinWidth="980"
                     MinHeight="680">

    <nebula:NebulaWindow.TitleBarContent>
        <Border Background="{DynamicResource Brush.Background}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14,7"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8"
                         Height="8"
                         Fill="{DynamicResource Brush.Success}"
                         Margin="0,0,8,0"
                         VerticalAlignment="Center"/>
                <TextBlock x:Name="ActiveThemeStatusText"
                           Text="NebulaDarkPurple theme active"
                           Style="{StaticResource Typography.TextBlock.Caption}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </nebula:NebulaWindow.TitleBarContent>

    <Grid>
        <DockPanel>
            <Menu DockPanel.Dock="Top"
                  Style="{StaticResource NebulaWindowMenu}">
                <MenuItem Header="File">
                    <MenuItem Header="New item"/>
                    <MenuItem Header="Open"/>
                    <Separator Style="{StaticResource NebulaMenuSeparator}"/>
                    <MenuItem Header="Exit"
                              Click="ExitMenuItem_Click"/>
                </MenuItem>
                <MenuItem Header="Edit">
                    <MenuItem Header="Undo"/>
                    <MenuItem Header="Redo"/>
                </MenuItem>
                <MenuItem Header="View">
                    <MenuItem Header="Controls"/>
                    <MenuItem Header="Inputs"/>
                    <MenuItem Header="Data"/>
                    <MenuItem Header="More">
                        <MenuItem Header="Status bar"/>
                        <MenuItem Header="Diagnostics"/>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="Paramètre">
                    <MenuItem Header="Theme">
                        <MenuItem Header="NebulaDarkPurple"
                                  Click="ApplyDarkPurpleThemeMenuItem_Click"/>
                        <MenuItem Header="NebulaDarkBlue"
                                  Click="ApplyDarkBlueThemeMenuItem_Click"/>
                        <MenuItem Header="NebulaLightPurple"
                                  Click="ApplyLightPurpleThemeMenuItem_Click"/>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="Help">
                    <MenuItem Header="About NebulaControls"/>
                </MenuItem>
            </Menu>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <nebula:NebulaSidebar x:Name="DemoSidebar"
                                      Title="Gallery"
                                      Description="Browse the current NebulaControls surface and component states."
                                      SelectionChanged="DemoSidebar_SelectionChanged">
                    <nebula:NebulaSidebarItem Content="Buttons + Feedback"
                                               Icon="&#xE8FD;"
                                               Tag="Actions"/>
                    <nebula:NebulaSidebarItem Content="Inputs + Progress"
                                               Icon="&#xE70F;"
                                               Tag="Inputs"/>
                    <nebula:NebulaSidebarItem Content="Collections + Data"
                                               Icon="&#xE8A5;"
                                               Tag="Collections"/>
                    <nebula:NebulaSidebarItem Content="Control Inventory"
                                               Icon="&#xE8EC;"
                                               Tag="Inventory"/>
                    <nebula:NebulaSidebarItem Content="Containers + Layout"
                                               Icon="&#xE8A9;"
                                               Tag="Containers"/>
                </nebula:NebulaSidebar>

                <Grid Grid.Column="1"
                      Margin="28,22,26,26">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                                <TextBlock Text="Control Gallery"
                                           Style="{StaticResource Typography.TextBlock.PageTitle}"/>
                                <TextBlock Text="A focused preview surface for NebulaControls components, interaction states, and theme resources."
                                           Style="{StaticResource Typography.TextBlock.Secondary}"
                                           TextWrapping="Wrap"
                                           Margin="0,8,24,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Top">
                            <nebula:NebulaBadge Style="{StaticResource NebulaInfoBadge}"
                                                Content="WPF"
                                                Margin="0,0,10,0"/>
                            <nebula:NebulaBadge Style="{StaticResource NebulaPurpleBadge}"
                                                Content="Nebula"/>
                        </StackPanel>
                    </Grid>

                    <ContentControl x:Name="DemoContentHost"
                                    Grid.Row="1"
                                    Margin="0,28,0,0"/>
                </Grid>
            </Grid>
            </DockPanel>

        <nebula:NebulaToastHost x:Name="ToastHost"/>
    </Grid>
</nebula:NebulaWindow>

