<UserControl x:Class="NebulaControls.Demo.Views.ButtonsFeedbackView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:nebula="clr-namespace:NebulaControls.Controls;assembly=NebulaControls">
    <ScrollViewer
        VerticalScrollBarVisibility="Auto">
        <UniformGrid Columns="2">
            <Border Style="{StaticResource DemoCard}">
                <StackPanel>
                    <TextBlock Text="Buttons"
                               Style="{StaticResource DemoSectionTitle}"/>
                    <TextBlock Text="Small buttons"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,16,0,8"/>
                    <TextBlock Text="Active"
                               Style="{StaticResource Typography.TextBlock.Muted}"
                               Margin="0,0,0,6"/>
                    <WrapPanel>
                        <Button Content="Primary"
                                Style="{StaticResource NebulaPrimarySmallButton}"
                                Margin="0,0,10,8"/>
                        <Button Content="Secondary"
                                Style="{StaticResource NebulaSecondarySmallButton}"
                                Margin="0,0,10,8"/>
                        <Button Content="Ghost"
                                Style="{StaticResource NebulaGhostSmallButton}"
                                Margin="0,0,10,8"/>
                    </WrapPanel>
                    <TextBlock Text="Inactive"
                               Style="{StaticResource Typography.TextBlock.Muted}"
                               Margin="0,0,0,6"/>
                    <WrapPanel>
                        <Button Content="Primary"
                                Style="{StaticResource NebulaPrimarySmallButton}"
                                IsEnabled="False"
                                Margin="0,0,10,14"/>
                        <Button Content="Secondary"
                                Style="{StaticResource NebulaSecondarySmallButton}"
                                IsEnabled="False"
                                Margin="0,0,10,14"/>
                        <Button Content="Ghost"
                                Style="{StaticResource NebulaGhostSmallButton}"
                                IsEnabled="False"
                                Margin="0,0,10,14"/>
                    </WrapPanel>

                    <TextBlock Text="Normal buttons"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,2,0,8"/>
                    <TextBlock Text="Active"
                               Style="{StaticResource Typography.TextBlock.Muted}"
                               Margin="0,0,0,6"/>
                    <WrapPanel>
                        <Button Content="Primary"
                                Style="{StaticResource NebulaPrimaryButton}"
                                Margin="0,0,10,8"/>
                        <Button Content="Secondary"
                                Style="{StaticResource NebulaSecondaryButton}"
                                Margin="0,0,10,8"/>
                        <Button Content="Ghost"
                                Style="{StaticResource NebulaGhostButton}"
                                Margin="0,0,10,8"/>
                    </WrapPanel>
                    <TextBlock Text="Inactive"
                               Style="{StaticResource Typography.TextBlock.Muted}"
                               Margin="0,0,0,6"/>
                    <WrapPanel>
                        <Button Content="Primary"
                                Style="{StaticResource NebulaPrimaryButton}"
                                IsEnabled="False"
                                Margin="0,0,10,14"/>
                        <Button Content="Secondary"
                                Style="{StaticResource NebulaSecondaryButton}"
                                IsEnabled="False"
                                Margin="0,0,10,14"/>
                        <Button Content="Ghost"
                                Style="{StaticResource NebulaGhostButton}"
                                IsEnabled="False"
                                Margin="0,0,10,14"/>
                    </WrapPanel>

                    <TextBlock Text="Large buttons"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,2,0,8"/>
                    <TextBlock Text="Active"
                               Style="{StaticResource Typography.TextBlock.Muted}"
                               Margin="0,0,0,6"/>
                    <WrapPanel>
                        <Button Content="Primary"
                                Style="{StaticResource NebulaPrimaryLargeButton}"
                                Margin="0,0,10,8"/>
                        <Button Content="Secondary"
                                Style="{StaticResource NebulaSecondaryLargeButton}"
                                Margin="0,0,10,8"/>
                        <Button Content="Ghost"
                                Style="{StaticResource NebulaGhostLargeButton}"
                                Margin="0,0,10,8"/>
                    </WrapPanel>
                    <TextBlock Text="Inactive"
                               Style="{StaticResource Typography.TextBlock.Muted}"
                               Margin="0,0,0,6"/>
                    <WrapPanel>
                        <Button Content="Primary"
                                Style="{StaticResource NebulaPrimaryLargeButton}"
                                IsEnabled="False"
                                Margin="0,0,10,0"/>
                        <Button Content="Secondary"
                                Style="{StaticResource NebulaSecondaryLargeButton}"
                                IsEnabled="False"
                                Margin="0,0,10,0"/>
                        <Button Content="Ghost"
                                Style="{StaticResource NebulaGhostLargeButton}"
                                IsEnabled="False"
                                Margin="0,0,10,0"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoCard}">
                <StackPanel>
                    <TextBlock Text="Badges"
                               Style="{StaticResource DemoSectionTitle}"/>
                    <TextBlock Text="Variants"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,16,0,8"/>
                    <WrapPanel>
                        <nebula:NebulaBadge Content="Default"
                                            Style="{StaticResource NebulaBadge}"
                                            Margin="0,0,10,10"/>
                        <nebula:NebulaBadge Content="Brand"
                                            Style="{StaticResource NebulaPurpleBadge}"
                                            Margin="0,0,10,10"/>
                        <nebula:NebulaBadge Content="Info"
                                            Style="{StaticResource NebulaInfoBadge}"
                                            Margin="0,0,10,10"/>
                        <nebula:NebulaBadge Content="Success"
                                            Style="{StaticResource NebulaSuccessBadge}"
                                            Margin="0,0,10,10"/>
                        <nebula:NebulaBadge Content="Warning"
                                            Style="{StaticResource NebulaWarningBadge}"
                                            Margin="0,0,10,10"/>
                        <nebula:NebulaBadge Content="Danger"
                                            Style="{StaticResource NebulaDangerBadge}"
                                            Margin="0,0,10,10"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoCard}">
                <StackPanel>
                    <TextBlock Text="Chips"
                               Style="{StaticResource DemoSectionTitle}"/>
                    <TextBlock Text="Filter control catalog"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,16,0,8"/>
                    <WrapPanel x:Name="ActiveFiltersPanel"
                               Margin="0,0,0,12">
                        <nebula:NebulaChip x:Name="InputFilterChip"
                                           Content="Inputs"
                                           Style="{StaticResource NebulaBrandChip}"
                                           IsSelected="True"
                                           IsCloseVisible="True"
                                           CloseClicked="FilterChip_CloseClicked"
                                           MouseLeftButtonUp="FilterChip_MouseLeftButtonUp"
                                           Margin="0,0,10,10"/>
                        <nebula:NebulaChip x:Name="FeedbackFilterChip"
                                           Content="Feedback"
                                           Style="{StaticResource NebulaSuccessChip}"
                                           IsSelected="True"
                                           IsCloseVisible="True"
                                           CloseClicked="FilterChip_CloseClicked"
                                           MouseLeftButtonUp="FilterChip_MouseLeftButtonUp"
                                           Margin="0,0,10,10"/>
                        <nebula:NebulaChip x:Name="NewFilterChip"
                                           Content="New controls"
                                           Style="{StaticResource NebulaWarningChip}"
                                           IsSelected="True"
                                           Visibility="Collapsed"
                                           IsCloseVisible="True"
                                           CloseClicked="FilterChip_CloseClicked"
                                           MouseLeftButtonUp="FilterChip_MouseLeftButtonUp"
                                           Margin="0,0,10,10"/>
                    </WrapPanel>

                    <TextBlock Text="Available filters"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <WrapPanel Margin="0,0,0,12">
                        <nebula:NebulaChip Content="Inputs"
                                           Tag="Inputs"
                                           Style="{StaticResource NebulaBrandChip}"
                                           MouseLeftButtonUp="AddFilterChip_MouseLeftButtonUp"
                                           Margin="0,0,10,10"/>
                        <nebula:NebulaChip Content="Feedback"
                                           Tag="Feedback"
                                           Style="{StaticResource NebulaSuccessChip}"
                                           MouseLeftButtonUp="AddFilterChip_MouseLeftButtonUp"
                                           Margin="0,0,10,10"/>
                        <nebula:NebulaChip Content="New controls"
                                           Tag="New controls"
                                           Style="{StaticResource NebulaWarningChip}"
                                           MouseLeftButtonUp="AddFilterChip_MouseLeftButtonUp"
                                           Margin="0,0,10,10"/>
                    </WrapPanel>

                    <TextBlock x:Name="FilterStatusText"
                               Text="Showing filtered controls."
                               Style="{StaticResource Typography.TextBlock.Muted}"
                               Margin="0,0,0,10"/>

                    <nebula:NebulaListBox x:Name="ChipFilteredControlsListBox"
                                           Style="{StaticResource NebulaListBox}"
                                           Width="360"
                                           Height="142"
                                           HorizontalAlignment="Left"
                                           Margin="0,0,0,18">
                        <nebula:NebulaListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}"
                                               Style="{StaticResource Typography.TextBlock.Strong}"/>
                                    <TextBlock Text="{Binding Category}"
                                               Style="{StaticResource Typography.TextBlock.Brand}"
                                               Margin="0,3,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </nebula:NebulaListBox.ItemTemplate>
                    </nebula:NebulaListBox>

                    <TextBlock Text="Variants"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <WrapPanel>
                        <nebula:NebulaChip Content="Default"
                                           Style="{StaticResource NebulaChip}"
                                           Margin="0,0,10,10"/>
                        <nebula:NebulaChip Content="Brand"
                                           Style="{StaticResource NebulaBrandChip}"
                                           Margin="0,0,10,10"/>
                        <nebula:NebulaChip Content="Success"
                                           Style="{StaticResource NebulaSuccessChip}"
                                           Margin="0,0,10,10"/>
                        <nebula:NebulaChip Content="Warning"
                                           Style="{StaticResource NebulaWarningChip}"
                                           Margin="0,0,10,10"/>
                        <nebula:NebulaChip Content="Danger"
                                           Style="{StaticResource NebulaDangerChip}"
                                           Margin="0,0,10,10"/>
                        <nebula:NebulaChip Content="Disabled"
                                           Style="{StaticResource NebulaChip}"
                                           IsEnabled="False"
                                           Margin="0,0,10,10"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoCard}">
                <StackPanel>
                    <TextBlock Text="Alerts"
                               Style="{StaticResource DemoSectionTitle}"/>
                    <WrapPanel Margin="0,16,0,12">
                        <Button Content="Info"
                                Style="{StaticResource NebulaSecondarySmallButton}"
                                Click="ShowInfoAlertButton_Click"
                                Margin="0,0,10,10"/>
                        <Button Content="Save"
                                Style="{StaticResource NebulaPrimarySmallButton}"
                                Click="ShowSuccessAlertButton_Click"
                                Margin="0,0,10,10"/>
                        <Button Content="Validate"
                                Style="{StaticResource NebulaWarningSmallButton}"
                                Click="ShowWarningAlertButton_Click"
                                Margin="0,0,10,10"/>
                        <Button Content="Fail"
                                Style="{StaticResource NebulaDangerSmallButton}"
                                Click="ShowDangerAlertButton_Click"
                                Margin="0,0,10,10"/>
                    </WrapPanel>
                    <nebula:NebulaAlert x:Name="InteractiveAlert"
                                        Style="{StaticResource NebulaInfoAlert}"
                                        Margin="0,16,0,10">
                        <StackPanel>
                            <TextBlock x:Name="InteractiveAlertTitle"
                                       Text="Information"
                                       Style="{StaticResource Typography.TextBlock.Strong}"/>
                            <TextBlock x:Name="InteractiveAlertMessage"
                                       Text="Use inline alerts to explain a state without interrupting the user."
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </nebula:NebulaAlert>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoCard}">
                <StackPanel>
                    <TextBlock Text="Toast"
                               Style="{StaticResource DemoSectionTitle}"/>
                    <TextBlock Text="Temporary in-app notification"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,16,0,8"/>
                    <WrapPanel Margin="0,0,0,16">
                        <Button Content="Info"
                                Style="{StaticResource NebulaSecondarySmallButton}"
                                Click="ShowInfoToastButton_Click"
                                Margin="0,0,10,10"/>
                        <Button Content="Saved"
                                Style="{StaticResource NebulaPrimarySmallButton}"
                                Click="ShowSuccessToastButton_Click"
                                Margin="0,0,10,10"/>
                        <Button Content="Warning"
                                Style="{StaticResource NebulaWarningSmallButton}"
                                Click="ShowWarningToastButton_Click"
                                Margin="0,0,10,10"/>
                        <Button Content="Danger"
                                Style="{StaticResource NebulaDangerSmallButton}"
                                Click="ShowDangerToastButton_Click"
                                Margin="0,0,10,10"/>
                    </WrapPanel>
                    <TextBlock Text="Toast appears at the bottom-right of the demo window for 5 seconds."
                               Style="{StaticResource Typography.TextBlock.Muted}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoCard}">
                <StackPanel>
                    <TextBlock Text="Rating"
                               Style="{StaticResource DemoSectionTitle}"/>
                    <TextBlock Text="Feedback score"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,16,0,8"/>
                    <nebula:NebulaRating x:Name="FeedbackRating"
                                         Style="{StaticResource NebulaRating}"
                                         Value="4"
                                         ValueChanged="FeedbackRating_ValueChanged"
                                         HorizontalAlignment="Left"
                                         Margin="0,0,0,8"/>
                    <TextBlock x:Name="FeedbackRatingText"
                               Text="4 / 5 - Very useful"
                               Style="{StaticResource Typography.TextBlock.Muted}"
                               Margin="0,0,0,18"/>

                    <TextBlock Text="Read-only"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <nebula:NebulaRating Style="{StaticResource NebulaRating}"
                                         Value="3"
                                         IsReadOnly="True"
                                         HorizontalAlignment="Left"
                                         Margin="0,0,0,18"/>

                    <TextBlock Text="Disabled"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <nebula:NebulaRating Style="{StaticResource NebulaRating}"
                                         Value="2"
                                         IsEnabled="False"
                                         HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoCard}">
                <StackPanel>
                    <TextBlock Text="Dialog"
                               Style="{StaticResource DemoSectionTitle}"/>
                    <TextBlock Text="Modal feedback and confirmations"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,16,0,8"/>
                    <WrapPanel Margin="0,0,0,12">
                        <Button Content="Information"
                                Style="{StaticResource NebulaSecondaryButton}"
                                Click="ShowInfoDialogButton_Click"
                                Margin="0,0,10,10"/>
                        <Button Content="Save"
                                Style="{StaticResource NebulaPrimaryButton}"
                                Click="ShowSaveDialogButton_Click"
                                Margin="0,0,10,10"/>
                        <Button Content="Delete"
                                Style="{StaticResource NebulaDangerButton}"
                                Click="ShowDeleteDialogButton_Click"
                                Margin="0,0,10,10"/>
                        <Button Content="Unsaved"
                                Style="{StaticResource NebulaSecondaryButton}"
                                Click="ShowUnsavedDialogButton_Click"
                                Margin="0,0,10,10"/>
                    </WrapPanel>
                    <TextBlock x:Name="DialogResultText"
                               Text="Choose a dialog scenario."
                               Style="{StaticResource Typography.TextBlock.Muted}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </UniformGrid>
    </ScrollViewer>
</UserControl>
