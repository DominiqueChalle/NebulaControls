<UserControl x:Class="NebulaControls.Demo.Views.PickerLabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <UniformGrid Columns="2">
            <Border Style="{StaticResource DemoCard}">
                <StackPanel>
                    <TextBlock Text="Native WPF DatePicker"
                               Style="{StaticResource DemoSectionTitle}"/>
                    <TextBlock Text="Reference control for popup behavior, keyboard input, selected date and disabled state."
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               TextWrapping="Wrap"
                               Margin="0,16,0,14"/>

                    <TextBlock Text="Standard"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <DatePicker SelectedDate="2026-06-21"
                                Width="260"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,16"/>

                    <TextBlock Text="Limited range"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <DatePicker SelectedDate="2026-06-21"
                                DisplayDateStart="2026-06-01"
                                DisplayDateEnd="2026-06-30"
                                Width="260"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,16"/>

                    <TextBlock Text="Disabled"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <DatePicker SelectedDate="2026-06-21"
                                IsEnabled="False"
                                Width="260"
                                HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoCard}">
                <StackPanel>
                    <TextBlock Text="Native WPF Calendar"
                               Style="{StaticResource DemoSectionTitle}"/>
                    <TextBlock Text="Useful to observe month, year and decade navigation before designing NebulaCalendarView."
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               TextWrapping="Wrap"
                               Margin="0,16,0,14"/>

                    <Calendar SelectedDate="2026-06-21"
                              DisplayDate="2026-06-21"
                              HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoCard}">
                <StackPanel>
                    <TextBlock Text="TimePicker Behavior Draft"
                               Style="{StaticResource DemoSectionTitle}"/>
                    <TextBlock Text="WPF has no native TimePicker. This is only a neutral behavior mock for the future NebulaTimePicker."
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               TextWrapping="Wrap"
                               Margin="0,16,0,14"/>

                    <TextBlock Text="Text entry"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <TextBox Text="14:30"
                             Width="160"
                             HorizontalAlignment="Left"
                             Margin="0,0,0,16"/>

                    <TextBlock Text="Preset selection"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <ComboBox SelectedIndex="2"
                              Width="160"
                              HorizontalAlignment="Left">
                        <ComboBoxItem Content="08:00"/>
                        <ComboBoxItem Content="12:00"/>
                        <ComboBoxItem Content="14:30"/>
                        <ComboBoxItem Content="18:00"/>
                    </ComboBox>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoCard}">
                <StackPanel>
                    <TextBlock Text="DateTimePicker Behavior Draft"
                               Style="{StaticResource DemoSectionTitle}"/>
                    <TextBlock Text="WPF has no native DateTimePicker. This composition helps define the future NebulaDateTimePicker experience."
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               TextWrapping="Wrap"
                               Margin="0,16,0,14"/>

                    <TextBlock Text="Date + time composition"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <DatePicker SelectedDate="2026-06-21"
                                    Width="180"/>
                        <TextBox Text="14:30"
                                 Width="90"
                                 Margin="12,0,0,0"/>
                    </StackPanel>

                    <TextBlock Text="Things to decide later: popup layout, keyboard behavior, min/max date-time, clear button and validation."
                               Style="{StaticResource Typography.TextBlock.Muted}"
                               TextWrapping="Wrap"
                               Margin="0,18,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>
    </ScrollViewer>
</UserControl>
