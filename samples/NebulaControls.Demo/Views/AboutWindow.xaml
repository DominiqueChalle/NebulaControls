<nebula:NebulaWindow x:Class="NebulaControls.Demo.Views.AboutWindow"
                     xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:nebula="clr-namespace:NebulaControls.Controls;assembly=NebulaControls"
                     Title="About NebulaControls"
                     Subtitle="WPF control library"
                     IconContent="N"
                     Style="{StaticResource NebulaWindow}"
                     Width="620"
                     Height="500"
                     MinWidth="560"
                     MinHeight="450"
                     ResizeMode="NoResize"
                     WindowStartupLocation="CenterOwner">

    <nebula:NebulaWindow.TitleBarContent>
        <Border Background="{DynamicResource Brush.Background}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8"
                         Height="8"
                         Fill="{DynamicResource Brush.Success}"
                         Margin="0,0,8,0"
                         VerticalAlignment="Center"/>
                <TextBlock Text="Public beta"
                           Style="{StaticResource Typography.TextBlock.Caption}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </nebula:NebulaWindow.TitleBarContent>

    <Grid Background="{DynamicResource Brush.Background}"
          Margin="24">
        <Border Style="{StaticResource DemoCard}"
                Width="555"
                MinHeight="320"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="48"
                                Height="48"
                                Background="{DynamicResource Brush.SurfaceActive}"
                                BorderBrush="{DynamicResource Brush.BrandSoft}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Margin="0,0,14,0">
                            <TextBlock Text="N"
                                       Style="{StaticResource Typography.TextBlock.BrandStrong}"
                                       FontSize="{StaticResource FontSize.PageTitle}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="NebulaControls"
                                       Style="{StaticResource Typography.TextBlock.PageTitle}"/>
                            <TextBlock Text="Reusable WPF controls with Nebula themes."
                                       Style="{StaticResource Typography.TextBlock.Secondary}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="NebulaControls is a public beta package focused on practical desktop controls, reusable styles, and runtime theme switching."
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               TextWrapping="Wrap"
                               Margin="0,22,0,0"/>
                </StackPanel>

                <Grid Grid.Row="1"
                      Margin="0,22,0,22">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Package"
                               Style="{StaticResource Typography.TextBlock.Label}"/>
                    <TextBlock Grid.Column="1"
                               Text="NebulaControls"
                               Style="{StaticResource Typography.TextBlock.Strong}"/>

                    <TextBlock Grid.Row="1"
                               Text="Version"
                               Style="{StaticResource Typography.TextBlock.Label}"
                               Margin="0,12,0,0"/>
                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               Text="1.0.2-beta"
                               Style="{StaticResource Typography.TextBlock.Brand}"
                               Margin="0,12,0,0"/>

                    <TextBlock Grid.Row="2"
                               Text="Repository"
                               Style="{StaticResource Typography.TextBlock.Label}"
                               Margin="0,12,0,0"/>
                    <TextBlock Grid.Row="2"
                               Grid.Column="1"
                               Text="github.com/DominiqueChalle/NebulaControls"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               TextWrapping="Wrap"
                               Margin="0,12,0,0"/>

                    <TextBlock Grid.Row="3"
                               Text="Status"
                               Style="{StaticResource Typography.TextBlock.Label}"
                               Margin="0,12,0,0"/>
                    <TextBlock Grid.Row="3"
                               Grid.Column="1"
                               Text="Usable beta. Controls continue to evolve through real feedback."
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               TextWrapping="Wrap"
                               Margin="0,12,0,0"/>
                </Grid>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Close"
                            Style="{StaticResource NebulaPrimaryButton}"
                            Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</nebula:NebulaWindow>
