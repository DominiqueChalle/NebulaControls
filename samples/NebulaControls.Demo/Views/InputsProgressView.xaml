<UserControl x:Class="NebulaControls.Demo.Views.InputsProgressView"
             x:Name="InputsProgressRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:nebula="clr-namespace:NebulaControls.Controls;assembly=NebulaControls">
    <ScrollViewer
        VerticalScrollBarVisibility="Auto">
        <UniformGrid Columns="2">
            <Border Style="{StaticResource DemoCard}">
                <StackPanel>
                    <TextBlock Text="TextBoxes"
                               Style="{StaticResource DemoSectionTitle}"/>

                    <TextBlock Text="Standard TextBox"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,16,0,8"/>
                    <TextBox Text="Nebula text value"
                             Style="{StaticResource NebulaTextBox}"
                             Width="300"
                             HorizontalAlignment="Left"
                             Margin="0,0,0,10"/>
                    <nebula:NebulaTextBox Style="{StaticResource NebulaTextBox}"
                                          Placeholder="Placeholder text"
                                          Width="300"
                                          HorizontalAlignment="Left"
                                          Margin="0,0,0,10"/>
                    <TextBox Text="Read-only value"
                             Style="{StaticResource NebulaTextBox}"
                             IsReadOnly="True"
                             Width="300"
                             HorizontalAlignment="Left"
                             Margin="0,0,0,10"/>
                    <TextBox Text="Disabled value"
                             Style="{StaticResource NebulaTextBox}"
                             IsEnabled="False"
                             Width="300"
                             HorizontalAlignment="Left"
                             Margin="0,0,0,16"/>

                    <TextBlock Text="Labeled TextBox"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <nebula:NebulaTextBox Style="{StaticResource NebulaLabeledTextBox}"
                                          Label="Username"
                                          Placeholder="Enter username"
                                          Text="domin"
                                          Width="300"
                                          HorizontalAlignment="Left"
                                          Margin="0,0,0,10"/>
                    <TextBlock Text="Extended Labeled TextBox"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <nebula:NebulaTextBox Style="{StaticResource NebulaLabeledTextBox}"
                                          Label="Profile name"
                                          Placeholder="Enter profile name"
                                          HelperText="Displayed in your local demo profile."
                                          Text="domin"
                                          Width="300"
                                          HorizontalAlignment="Left"
                                          Margin="0,0,0,16"/>

                    <TextBlock Text="Validation"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <nebula:NebulaTextBox x:Name="EmailTextBox"
                                          Style="{StaticResource NebulaLabeledTextBox}"
                                          Label="Email"
                                          Placeholder="name@example.com"
                                          HelperText="Leave the field to validate the email address."
                                          Width="300"
                                          HorizontalAlignment="Left"
                                          LostFocus="EmailTextBox_LostFocus"
                                          Margin="0,0,0,16"/>

                    <TextBlock Text="Sizes"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,0,16">
                        <TextBox Text="Small"
                                 Style="{StaticResource NebulaSmallTextBox}"
                                 Width="96"
                                 HorizontalAlignment="Left"/>
                        <TextBox Text="Medium"
                                 Style="{StaticResource NebulaMediumTextBox}"
                                 Width="110"
                                 HorizontalAlignment="Left"
                                 Margin="16,0,0,0"/>
                        <TextBox Text="Large"
                                 Style="{StaticResource NebulaLargeTextBox}"
                                 Width="124"
                                 HorizontalAlignment="Left"
                                 Margin="16,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoCard}">
                <StackPanel>
                    <TextBlock Text="Password"
                               Style="{StaticResource DemoSectionTitle}"/>
                    <TextBlock Text="Standard PasswordBox"
                               Style="{StaticResource Typography.TextBlock.Muted}"
                               Margin="0,16,0,6"/>
                    <PasswordBox Style="{StaticResource NebulaPasswordBox}"
                                 Password="nebula"
                                 Width="300"
                                 HorizontalAlignment="Left"
                                 Margin="0,0,0,10"/>
                    <TextBlock Text="Labeled PasswordBox"
                               Style="{StaticResource Typography.TextBlock.Muted}"
                               Margin="0,0,0,6"/>
                    <nebula:NebulaLabeledPasswordBox Style="{StaticResource NebulaLabeledPasswordBox}"
                                                     Label="Password"
                                                     Password="nebula"
                                                     Width="300"
                                                     HorizontalAlignment="Left"
                                                     Margin="0,0,0,10"/>
                    <TextBlock Text="Extended Labeled PasswordBox"
                               Style="{StaticResource Typography.TextBlock.Muted}"
                               Margin="0,0,0,6"/>
                    <nebula:NebulaLabeledPasswordBox x:Name="PasswordValidationBox"
                                                     Style="{StaticResource NebulaLabeledPasswordBox}"
                                                     Label="Secure password"
                                                     Password="nebula!"
                                                     HelperText="Use at least 8 characters with a special character."
                                                     Width="300"
                                                     HorizontalAlignment="Left"
                                                     LostFocus="PasswordValidationBox_LostFocus"
                                                     Margin="0,0,0,16"/>
                    <TextBlock Text="Sizes follow the same Small / Medium / Large scale as TextBox."
                               Style="{StaticResource Typography.TextBlock.Muted}"
                               Margin="0,0,0,0"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoCard}">
                <StackPanel>
                    <TextBlock Text="DatePicker"
                               Style="{StaticResource DemoSectionTitle}"/>
                    <TextBlock Text="Standard DatePicker"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,16,0,8"/>
                    <nebula:NebulaDatePicker Style="{StaticResource NebulaDatePicker}"
                                             SelectedDate="2026-06-21"
                                             Width="300"
                                             HorizontalAlignment="Left"
                                             Margin="0,0,0,16"/>

                    <TextBlock Text="Limited range"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <nebula:NebulaDatePicker Style="{StaticResource NebulaDatePicker}"
                                             SelectedDate="2026-06-21"
                                             DisplayDateStart="2026-06-01"
                                             DisplayDateEnd="2026-06-30"
                                             Width="300"
                                             HorizontalAlignment="Left"
                                             Margin="0,0,0,16"/>

                    <TextBlock Text="Disabled DatePicker"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <nebula:NebulaDatePicker Style="{StaticResource NebulaDatePicker}"
                                             SelectedDate="2026-06-21"
                                             IsEnabled="False"
                                             Width="300"
                                             HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoCard}">
                <StackPanel>
                    <TextBlock Text="TimePicker"
                               Style="{StaticResource DemoSectionTitle}"/>
                    <TextBlock Text="Standard TimePicker"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,16,0,8"/>
                    <nebula:NebulaTimePicker Style="{StaticResource NebulaTimePicker}"
                                             SelectedTime="14:30"
                                             Width="180"
                                             HorizontalAlignment="Left"
                                             Margin="0,0,0,16"/>

                    <TextBlock Text="Manual entry accepts HH:mm"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <nebula:NebulaTimePicker Style="{StaticResource NebulaTimePicker}"
                                             SelectedTime="08:05"
                                             Width="180"
                                             HorizontalAlignment="Left"
                                             Margin="0,0,0,16"/>

                    <TextBlock Text="Disabled TimePicker"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <nebula:NebulaTimePicker Style="{StaticResource NebulaTimePicker}"
                                             SelectedTime="18:00"
                                             IsEnabled="False"
                                             Width="180"
                                             HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoCard}">
                <StackPanel>
                    <TextBlock Text="NumericUpDown"
                               Style="{StaticResource DemoSectionTitle}"/>
                    <TextBlock Text="Standard"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,16,0,8"/>
                    <nebula:NebulaNumericUpDown Style="{StaticResource NebulaNumericUpDown}"
                                                Value="12"
                                                Width="180"
                                                HorizontalAlignment="Left"
                                                Margin="0,0,0,16"/>

                    <TextBlock Text="Limited range"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <nebula:NebulaNumericUpDown Style="{StaticResource NebulaNumericUpDown}"
                                                Value="5"
                                                Minimum="0"
                                                Maximum="10"
                                                Step="1"
                                                Width="180"
                                                HorizontalAlignment="Left"
                                                Margin="0,0,0,16"/>

                    <TextBlock Text="Decimal step"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <nebula:NebulaNumericUpDown Style="{StaticResource NebulaNumericUpDown}"
                                                Value="2.5"
                                                Minimum="0"
                                                Maximum="5"
                                                Step="0.5"
                                                Width="180"
                                                HorizontalAlignment="Left"
                                                Margin="0,0,0,16"/>

                    <TextBlock Text="Read-only"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <nebula:NebulaNumericUpDown Style="{StaticResource NebulaNumericUpDown}"
                                                Value="42"
                                                IsReadOnly="True"
                                                Width="180"
                                                HorizontalAlignment="Left"
                                                Margin="0,0,0,16"/>

                    <TextBlock Text="Disabled"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <nebula:NebulaNumericUpDown Style="{StaticResource NebulaNumericUpDown}"
                                                Value="64"
                                                IsEnabled="False"
                                                Width="180"
                                                HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoCard}">
                <StackPanel>
                    <TextBlock Text="SearchBox"
                               Style="{StaticResource DemoSectionTitle}"/>
                    <TextBlock Text="Filter a realistic control list"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,16,0,8"/>
                    <nebula:NebulaSearchBox Style="{StaticResource NebulaSearchBox}"
                                            Placeholder="Rechercher nom, catégorie, description..."
                                            SearchTextChanged="ControlSearchBox_SearchTextChanged"
                                            SearchSubmitted="ControlSearchBox_SearchSubmitted"
                                            Width="360"
                                            HorizontalAlignment="Left"
                                            Margin="0,0,0,14"/>

                    <TextBlock x:Name="SearchStatusText"
                               Text="Tapez pour filtrer la liste."
                               Style="{StaticResource Typography.TextBlock.Muted}"
                               Margin="0,0,0,10"/>

                    <nebula:NebulaListBox Style="{StaticResource NebulaListBox}"
                                          ItemsSource="{Binding FilteredSearchItems, ElementName=InputsProgressRoot}"
                                          Width="360"
                                          Height="230"
                                          HorizontalAlignment="Left">
                        <nebula:NebulaListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="{Binding Name}"
                                               Style="{StaticResource Typography.TextBlock.Strong}"/>
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding Category}"
                                               Style="{StaticResource Typography.TextBlock.Brand}"
                                               Margin="0,3,0,0"/>
                                    <TextBlock Grid.Row="2"
                                               Text="{Binding Description}"
                                               Style="{StaticResource Typography.TextBlock.Muted}"
                                               TextWrapping="Wrap"
                                               Margin="0,3,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </nebula:NebulaListBox.ItemTemplate>
                    </nebula:NebulaListBox>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoCard}">
                <StackPanel>
                    <TextBlock Text="Choices"
                               Style="{StaticResource DemoSectionTitle}"/>
                    <TextBlock Text="CheckBox"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,16,0,8"/>
                    <CheckBox Content="Unchecked option"
                              Style="{StaticResource NebulaCheckBox}"
                              Margin="0,0,0,10"/>
                    <CheckBox Content="Checked option"
                              Style="{StaticResource NebulaCheckBox}"
                              IsChecked="True"
                              Margin="0,0,0,10"/>
                    <CheckBox Content="Indeterminate option"
                              Style="{StaticResource NebulaCheckBox}"
                              IsThreeState="True"
                              IsChecked="{x:Null}"
                              Margin="0,0,0,10"/>
                    <CheckBox Content="Disabled option"
                              Style="{StaticResource NebulaCheckBox}"
                              IsEnabled="False"
                              Margin="0,0,0,16"/>

                    <TextBlock Text="RadioButton"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <RadioButton Content="First choice"
                                 GroupName="Choices"
                                 Style="{StaticResource NebulaRadioButton}"
                                 IsChecked="True"
                                 Margin="0,0,0,10"/>
                    <RadioButton Content="Second choice"
                                 GroupName="Choices"
                                 Style="{StaticResource NebulaRadioButton}"
                                 Margin="0,0,0,10"/>
                    <RadioButton Content="Disabled choice"
                                 GroupName="Choices"
                                 Style="{StaticResource NebulaRadioButton}"
                                 IsEnabled="False"
                                 Margin="0,0,0,16"/>

                    <TextBlock Text="ToggleButton"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <ToggleButton Content="Inactive setting"
                                  Style="{StaticResource NebulaToggleButton}"
                                  Margin="0,0,0,10"/>
                    <ToggleButton Content="Active setting"
                                  Style="{StaticResource NebulaToggleButton}"
                                  IsChecked="True"
                                  Margin="0,0,0,10"/>
                    <ToggleButton Content="Disabled setting"
                                  Style="{StaticResource NebulaToggleButton}"
                                  IsEnabled="False"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoCard}">
                <StackPanel>
                    <TextBlock Text="ComboBox"
                               Style="{StaticResource DemoSectionTitle}"/>
                    <TextBlock Text="Standard ComboBox"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,16,0,8"/>
                    <nebula:NebulaComboBox Style="{StaticResource NebulaComboBox}"
                                           Width="300"
                                           SelectedIndex="0"
                                           HorizontalAlignment="Left"
                                           Margin="0,0,0,16">
                        <ComboBoxItem Content="Nebula Dark Purple"/>
                        <ComboBoxItem Content="Package loaded"/>
                        <ComboBoxItem Content="External app"/>
                    </nebula:NebulaComboBox>

                    <TextBlock Text="With disabled item"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <nebula:NebulaComboBox Style="{StaticResource NebulaComboBox}"
                                           Width="300"
                                           SelectedIndex="1"
                                           HorizontalAlignment="Left"
                                           Margin="0,0,0,16">
                        <ComboBoxItem Content="Active option"/>
                        <ComboBoxItem Content="Disabled option"
                                      IsEnabled="False"/>
                        <ComboBoxItem Content="Another active option"/>
                    </nebula:NebulaComboBox>

                    <TextBlock Text="Editable ComboBox"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <nebula:NebulaComboBox Style="{StaticResource NebulaComboBox}"
                                           Width="300"
                                           IsEditable="True"
                                           SelectedIndex="0"
                                           HorizontalAlignment="Left"
                                           Margin="0,0,0,16">
                        <ComboBoxItem Content="Dark Purple"/>
                        <ComboBoxItem Content="Dark Blue"/>
                        <ComboBoxItem Content="Light Purple"/>
                    </nebula:NebulaComboBox>

                    <TextBlock Text="Disabled ComboBox"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <nebula:NebulaComboBox Style="{StaticResource NebulaComboBox}"
                                           Width="300"
                                           SelectedIndex="0"
                                           IsEnabled="False"
                                           HorizontalAlignment="Left">
                        <ComboBoxItem Content="Disabled selection"/>
                    </nebula:NebulaComboBox>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoCard}">
                <StackPanel>
                    <TextBlock Text="Slider"
                               Style="{StaticResource DemoSectionTitle}"/>
                    <TextBlock Text="Standard"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,16,0,8"/>
                    <nebula:NebulaSlider Style="{StaticResource NebulaSlider}"
                                         Width="320"
                                         Value="42"
                                         HorizontalAlignment="Left"
                                         Margin="0,0,0,16"/>
                    <TextBlock Text="With tick frequency"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <nebula:NebulaSlider Style="{StaticResource NebulaSlider}"
                                         Width="320"
                                         Value="58"
                                         TickFrequency="10"
                                         TickPlacement="BottomRight"
                                         HorizontalAlignment="Left"
                                         Margin="0,0,0,16"/>
                    <TextBlock Text="With custom ticks"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <nebula:NebulaSlider Style="{StaticResource NebulaSlider}"
                                         Width="320"
                                         Value="60"
                                         Minimum="0"
                                         Maximum="100"
                                         Ticks="0,20,40,60,80,100"
                                         TickPlacement="BottomRight"
                                         HorizontalAlignment="Left"
                                         Margin="0,0,0,16"/>
                    <TextBlock Text="Disabled"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <nebula:NebulaSlider Style="{StaticResource NebulaSlider}"
                                         Width="320"
                                         Value="48"
                                         IsEnabled="False"
                                         HorizontalAlignment="Left"
                                         Margin="0,0,0,16"/>
                    <TextBlock Text="Vertical"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,0,0">
                        <nebula:NebulaSlider Style="{StaticResource NebulaSlider}"
                                             Orientation="Vertical"
                                             Height="150"
                                             Value="35"/>
                        <nebula:NebulaSlider Style="{StaticResource NebulaSlider}"
                                             Orientation="Vertical"
                                             Height="150"
                                             Value="65"
                                             TickFrequency="10"
                                             TickPlacement="BottomRight"
                                             Margin="44,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoCard}">
                <StackPanel>
                    <TextBlock Text="Progress"
                               Style="{StaticResource DemoSectionTitle}"/>
                    <TextBlock Text="Determinate"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,16,0,8"/>
                    <nebula:NebulaProgressBar Style="{StaticResource NebulaProgressBar}"
                                              Width="320"
                                              Value="64"
                                              HorizontalAlignment="Left"
                                              Margin="0,0,0,16"/>
                    <TextBlock Text="Indeterminate"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <nebula:NebulaProgressBar Style="{StaticResource NebulaProgressBar}"
                                              Width="320"
                                              IsIndeterminate="True"
                                              HorizontalAlignment="Left"
                                              Margin="0,0,0,16"/>
                    <TextBlock Text="Disabled"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <nebula:NebulaProgressBar Style="{StaticResource NebulaProgressBar}"
                                              Width="320"
                                              Value="42"
                                              IsEnabled="False"
                                              HorizontalAlignment="Left"
                                              Margin="0,0,0,16"/>
                    <TextBlock Text="Spinner"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <nebula:NebulaSpinner Style="{StaticResource NebulaSpinner}"
                                              Width="42"
                                              Height="42"
                                              HorizontalAlignment="Left"/>
                        <nebula:NebulaSpinner Style="{StaticResource NebulaSpinner}"
                                              Width="42"
                                              Height="42"
                                              IsEnabled="False"
                                              Margin="24,0,0,0"
                                              HorizontalAlignment="Left"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </UniformGrid>
    </ScrollViewer>
</UserControl>
