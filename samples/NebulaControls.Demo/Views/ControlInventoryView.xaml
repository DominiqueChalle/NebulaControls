<UserControl x:Class="NebulaControls.Demo.Views.ControlInventoryView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:nebula="clr-namespace:NebulaControls.Controls;assembly=NebulaControls">
    <Grid>
        <Border Style="{StaticResource DemoCard}">
            <StackPanel>
                <TextBlock Text="Control Inventory"
                           Style="{StaticResource DemoSectionTitle}"/>
                <TextBlock Text="Read-only inventory of validated NebulaControls. This table is separated from the editable DataGrid sandbox."
                           Style="{StaticResource Typography.TextBlock.Secondary}"
                           TextWrapping="Wrap"
                           Margin="0,16,0,8"/>
                <nebula:NebulaDataGrid Style="{StaticResource NebulaDataGrid}"
                                       ItemsSource="{Binding InventoryRows, ElementName=Root}"
                                       AutoGenerateColumns="False"
                                       CanUserAddRows="False"
                                       IsReadOnly="True"
                                       Width="920"
                                       Height="520"
                                       HorizontalAlignment="Left"
                                       Margin="0,0,0,10">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Id"
                                            Binding="{Binding Id}"
                                            Width="70"/>
                        <DataGridTextColumn Header="Component"
                                            Binding="{Binding Component}"
                                            Width="180"/>
                        <DataGridTextColumn Header="Version"
                                            Binding="{Binding Version}"
                                            Width="90"/>
                        <DataGridTextColumn Header="Status"
                                            Binding="{Binding Status}"
                                            Width="120"/>
                        <DataGridTextColumn Header="Area"
                                            Binding="{Binding Area}"
                                            Width="130"/>
                        <DataGridTextColumn Header="Priority"
                                            Binding="{Binding Priority}"
                                            Width="110"/>
                        <DataGridTextColumn Header="Updated"
                                            Binding="{Binding Updated}"
                                            Width="130"/>
                        <DataGridTextColumn Header="Notes"
                                            Binding="{Binding Notes}"
                                            Width="320"/>
                    </DataGrid.Columns>
                </nebula:NebulaDataGrid>
                <TextBlock x:Name="InventoryStatusText"
                           Style="{StaticResource Typography.TextBlock.Muted}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
