<UserControl x:Class="NebulaControls.Demo.Views.ContainersLayoutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:NebulaControls.Demo.Behaviors"
             xmlns:nebula="clr-namespace:NebulaControls.Controls;assembly=NebulaControls">
    <ScrollViewer behaviors:ScrollFocusBehavior.TrackKeyboardFocus="True"
        VerticalScrollBarVisibility="Auto">
        <UniformGrid Columns="2"
                     KeyboardNavigation.TabNavigation="Cycle">
            <Border Style="{StaticResource DemoCard}">
                <StackPanel>
                    <TextBlock Text="Expander"
                               Style="{StaticResource DemoSectionTitle}"/>
                    <TextBlock x:Name="ExpanderStatusText"
                               Text="Advanced options are open"
                               Style="{StaticResource Typography.TextBlock.Brand}"
                               Margin="0,16,0,8"/>
                    <TextBlock Text="Interactive settings panel"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <nebula:NebulaExpander Style="{StaticResource NebulaExpander}"
                                           x:Name="AdvancedOptionsExpander"
                                           Header="Advanced options"
                                           IsExpanded="True"
                                           Expanded="AdvancedOptionsExpander_Expanded"
                                           Collapsed="AdvancedOptionsExpander_Collapsed"
                                           Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Expanded content surface"
                                       Style="{StaticResource Typography.TextBlock.Secondary}"/>
                            <CheckBox Content="Enable diagnostics"
                                      Style="{StaticResource NebulaCheckBox}"
                                      IsChecked="True"
                                      Margin="0,12,0,0"/>
                            <Button Content="Apply advanced options"
                                    Style="{StaticResource NebulaSecondarySmallButton}"
                                    HorizontalAlignment="Left"
                                    Click="ApplyAdvancedOptionsButton_Click"
                                    Margin="0,12,0,0"/>
                        </StackPanel>
                    </nebula:NebulaExpander>
                    <TextBlock Text="Collapsed"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <nebula:NebulaExpander Style="{StaticResource NebulaExpander}"
                                           Header="Collapsed options"
                                           Margin="0,0,0,12">
                        <TextBlock Text="Hidden until expanded"
                                   Style="{StaticResource Typography.TextBlock.Secondary}"/>
                    </nebula:NebulaExpander>
                    <TextBlock Text="Disabled"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <nebula:NebulaExpander Style="{StaticResource NebulaExpander}"
                                           Header="Disabled options"
                                           IsExpanded="True"
                                           IsEnabled="False">
                        <TextBlock Text="Disabled content"
                                   Style="{StaticResource Typography.TextBlock.Secondary}"/>
                    </nebula:NebulaExpander>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoCard}">
                <StackPanel>
                    <TextBlock Text="GroupBox"
                               Style="{StaticResource DemoSectionTitle}"/>
                    <TextBlock x:Name="GroupBoxStatusText"
                               Text="Settings ready"
                               Style="{StaticResource Typography.TextBlock.Brand}"
                               Margin="0,16,0,8"/>
                    <TextBlock Text="Grouped settings"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <nebula:NebulaGroupBox Style="{StaticResource NebulaGroupBox}"
                                           Header="Settings"
                                           Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="These controls belong to the same settings section."
                                       Style="{StaticResource Typography.TextBlock.Secondary}"/>
                            <ToggleButton x:Name="GroupBoxFeatureToggle"
                                          Content="Enable feature"
                                          Style="{StaticResource NebulaToggleButton}"
                                          IsChecked="True"
                                          Checked="GroupBoxSetting_Changed"
                                          Unchecked="GroupBoxSetting_Changed"
                                          Margin="0,14,0,0"/>
                            <CheckBox x:Name="GroupBoxNotificationCheckBox"
                                      Content="Send notifications"
                                      Style="{StaticResource NebulaCheckBox}"
                                      IsChecked="True"
                                      Checked="GroupBoxSetting_Changed"
                                      Unchecked="GroupBoxSetting_Changed"
                                      Margin="0,12,0,0"/>
                            <Button Content="Apply settings"
                                    Style="{StaticResource NebulaSecondarySmallButton}"
                                    HorizontalAlignment="Left"
                                    Click="ApplyGroupBoxSettingsButton_Click"
                                    Margin="0,12,0,0"/>
                        </StackPanel>
                    </nebula:NebulaGroupBox>
                    <TextBlock Text="Without header"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <nebula:NebulaGroupBox Style="{StaticResource NebulaGroupBox}"
                                           Margin="0,0,0,12">
                        <TextBlock Text="Content can be grouped without a visible header."
                                   Style="{StaticResource Typography.TextBlock.Secondary}"/>
                    </nebula:NebulaGroupBox>
                    <TextBlock Text="Disabled"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <nebula:NebulaGroupBox Style="{StaticResource NebulaGroupBox}"
                                           Header="Disabled settings"
                                           IsEnabled="False">
                        <ToggleButton Content="Unavailable"
                                      Style="{StaticResource NebulaToggleButton}"
                                      IsChecked="True"/>
                    </nebula:NebulaGroupBox>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoCard}">
                <StackPanel>
                    <TextBlock Text="TabControl"
                               Style="{StaticResource DemoSectionTitle}"/>
                    <TextBlock x:Name="TopTabStatusText"
                               Text="Selected tab: Overview"
                               Style="{StaticResource Typography.TextBlock.Brand}"
                               Margin="0,16,0,8"/>
                    <nebula:NebulaTabControl Style="{StaticResource NebulaTabControl}"
                                             SelectionChanged="TopTabControl_SelectionChanged">
                        <nebula:NebulaTabItem Header="Overview">
                            <StackPanel>
                                <TextBlock Text="Overview content"
                                           Style="{StaticResource Typography.TextBlock.Secondary}"/>
                                <TextBlock Text="Use this tab as a dashboard or summary surface."
                                           Style="{StaticResource Typography.TextBlock.Muted}"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </nebula:NebulaTabItem>
                        <nebula:NebulaTabItem Header="Details">
                            <StackPanel>
                                <TextBlock Text="Details content"
                                           Style="{StaticResource Typography.TextBlock.Secondary}"/>
                                <Button Content="Run details action"
                                        Style="{StaticResource NebulaSecondarySmallButton}"
                                        HorizontalAlignment="Left"
                                        Margin="0,12,0,0"/>
                            </StackPanel>
                        </nebula:NebulaTabItem>
                        <nebula:NebulaTabItem Header="Settings">
                            <StackPanel>
                                <TextBlock Text="Settings content"
                                           Style="{StaticResource Typography.TextBlock.Secondary}"/>
                                <CheckBox Content="Enable compact mode"
                                          Style="{StaticResource NebulaCheckBox}"
                                          Margin="0,12,0,0"/>
                            </StackPanel>
                        </nebula:NebulaTabItem>
                        <nebula:NebulaTabItem Header="Logs">
                            <StackPanel>
                                <TextBlock Text="Logs content"
                                           Style="{StaticResource Typography.TextBlock.Secondary}"/>
                                <TextBlock Text="Recent activity and diagnostic output."
                                           Style="{StaticResource Typography.TextBlock.Muted}"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </nebula:NebulaTabItem>
                        <nebula:NebulaTabItem Header="Disabled"
                                              IsEnabled="False">
                            <TextBlock Text="Disabled tab content"
                                       Style="{StaticResource Typography.TextBlock.Secondary}"/>
                        </nebula:NebulaTabItem>
                    </nebula:NebulaTabControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoCard}">
                <StackPanel>
                    <TextBlock Text="NebulaWindow"
                               Style="{StaticResource DemoSectionTitle}"/>
                    <TextBlock Text="Dedicated preview window"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,16,0,8"/>
                    <TextBlock Text="Opens a separate NebulaWindow so the shell can be tested without changing the main demo window."
                               Style="{StaticResource Typography.TextBlock.Muted}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16"/>
                    <Button Content="Open NebulaWindow"
                            Style="{StaticResource NebulaSecondaryButton}"
                            HorizontalAlignment="Left"
                            Click="OpenNebulaWindowButton_Click"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoCard}">
                <StackPanel>
                    <TextBlock Text="Avatar"
                               Style="{StaticResource DemoSectionTitle}"/>
                    <TextBlock Text="Built-in fallbacks"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,16,0,8"/>
                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,0,18">
                        <StackPanel Margin="0,0,22,0">
                            <nebula:NebulaAvatar Style="{StaticResource NebulaAvatar}"
                                                 AvatarKind="User"
                                                 HorizontalAlignment="Center"/>
                            <TextBlock Text="User"
                                       Style="{StaticResource Typography.TextBlock.Muted}"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,22,0">
                            <nebula:NebulaAvatar Style="{StaticResource NebulaAvatar}"
                                                 AvatarKind="Male"
                                                 HorizontalAlignment="Center"/>
                            <TextBlock Text="Male"
                                       Style="{StaticResource Typography.TextBlock.Muted}"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                        <StackPanel>
                            <nebula:NebulaAvatar Style="{StaticResource NebulaAvatar}"
                                                 AvatarKind="Female"
                                                 HorizontalAlignment="Center"/>
                            <TextBlock Text="Female"
                                       Style="{StaticResource Typography.TextBlock.Muted}"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="Load custom image"
                               Style="{StaticResource Typography.TextBlock.Secondary}"
                               Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <nebula:NebulaAvatar x:Name="LoadedAvatar"
                                             Style="{StaticResource NebulaLargeAvatar}"
                                             AvatarKind="User"/>
                        <StackPanel Margin="18,0,0,0"
                                    VerticalAlignment="Center">
                            <Button Content="Load avatar"
                                    Style="{StaticResource NebulaSecondaryButton}"
                                    Click="LoadAvatarButton_Click"
                                    Margin="0,0,0,8"/>
                            <TextBlock x:Name="LoadedAvatarStatusText"
                                       Text="No custom image loaded."
                                       Style="{StaticResource Typography.TextBlock.Muted}"
                                       TextWrapping="Wrap"
                                       Width="240"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

        </UniformGrid>
    </ScrollViewer>
</UserControl>
