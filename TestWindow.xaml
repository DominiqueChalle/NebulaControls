<Window x:Class="NebulaUI.TestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NebulaUI"
        mc:Ignorable="d"
        Title="TestWindow" Height="450" Width="800">

    <Border Background="{DynamicResource Brush.Background}"
            Padding="20">
        <Grid>
            <CheckBox 
                Style="{StaticResource NebulaSimpleCheckBox}"
                Content="CheckBox" HorizontalAlignment="Left" Margin="48,44,0,0" VerticalAlignment="Top" IsChecked="True" Width="166"/>

        </Grid>
    </Border>
</Window>
