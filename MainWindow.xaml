<Window x:Class="NebulaUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NebulaUI"
        xmlns:controls="clr-namespace:NebulaUI.Controls"
        mc:Ignorable="d"
        Title="NebulaUI Demo Gallery"
        Height="820"
        Width="1180"
        MinHeight="680"
        MinWidth="980"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="GalleryTitleText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
        </Style>

        <Style x:Key="GallerySubtitleText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
        </Style>

        <Style x:Key="GallerySectionTitleText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="GalleryLabelText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

    </Window.Resources>

    <!-- ============================================================================================= -->
    <!-- Header                                                                                        -->
    <!-- ============================================================================================= -->

    <Border Background="{DynamicResource Brush.Background}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,26">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel HorizontalAlignment="Center"
                                Grid.ColumnSpan="2">
                        <TextBlock Text="Welcome to NebulaUI!"
                                   Style="{StaticResource GalleryTitleText}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Experience the beauty of WPF with NebulaUI's Dark Purple theme."
                                   Style="{StaticResource GallerySubtitleText}"
                                   Margin="0,8,0,0"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="{DynamicResource Brush.Surface}"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16,10"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10"
                                     Height="10"
                                     Fill="{DynamicResource Brush.Accent}"
                                     Margin="0,0,8,0"/>
                            <TextBlock Text="Dark Purple"
                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ============================================================================================= -->
                <!-- Gallery                                                                                       -->
                <!-- ============================================================================================= -->


                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>


                    <StackPanel Grid.Column="0">

                        <!-- ================================================== -->
                        <!-- Buttons                                            -->
                        <!-- ================================================== -->
                        <Border Style="{StaticResource NebulaGalleryCard}">
                            <StackPanel>
                                <TextBlock Text="Buttons"
                                           Style="{StaticResource GallerySectionTitleText}"/>

                                <TextBlock Text="Primary and secondary actions"
                                           Style="{StaticResource GalleryLabelText}"/>
                                <WrapPanel Margin="-10,0,0,0">
                                    <Button Content="Primary"
                                            Style="{StaticResource NebulaPrimaryButton}"
                                            MinWidth="132"
                                            Height="44"/>
                                    <Button Content="Secondary"
                                            Style="{StaticResource NebulaSecondaryButton}"
                                            MinWidth="132"
                                            Height="44"/>
                                </WrapPanel>

                                <TextBlock Text="Disabled states"
                                           Style="{StaticResource GalleryLabelText}"
                                           Margin="0,22,0,6"/>
                                <WrapPanel Margin="-10,0,0,0">
                                    <Button Content="Primary"
                                            Style="{StaticResource NebulaPrimaryButton}"
                                            MinWidth="132"
                                            Height="44"
                                            IsEnabled="False"/>
                                    <Button Content="Secondary"
                                            Style="{StaticResource NebulaSecondaryButton}"
                                            MinWidth="132"
                                            Height="44"
                                            IsEnabled="False"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- ==================================================== -->
                        <!-- CheckBox                                             -->
                        <!-- ==================================================== -->
                        <Border Style="{StaticResource NebulaGalleryCard}">
                            <StackPanel>
                                <TextBlock Text="CheckBox"
                                           Style="{StaticResource GallerySectionTitleText}"/>

                                <CheckBox Content="Unchecked option"
                                          Style="{StaticResource NebulaCheckBox}"
                                          Margin="0,0,0,12"
                                          IsChecked="False"/>
                                <CheckBox Content="Checked option"
                                          Style="{StaticResource NebulaCheckBox}"
                                          Margin="0,0,0,12"
                                          IsChecked="True"/>
                                <CheckBox Content="Indeterminate option"
                                          Style="{StaticResource NebulaCheckBox}"
                                          Margin="0,0,0,12"
                                          IsThreeState="True"
                                          IsChecked="{x:Null}"/>
                                <CheckBox Content="Disabled option"
                                          Style="{StaticResource NebulaCheckBox}"
                                          IsChecked="True"
                                          IsEnabled="False"/>
                            </StackPanel>
                        </Border>

                        <!-- ================================================== -->
                        <!-- ToggleButton                                       -->
                        <!-- ================================================== -->
                        <Border Style="{StaticResource NebulaGalleryCard}">
                            <StackPanel>
                                <TextBlock Text="ToggleButton"
                                           Style="{StaticResource GallerySectionTitleText}"/>

                                <ToggleButton Content="Inactive setting"
                                              Style="{StaticResource NebulaToggleButton}"
                                              Margin="0,0,0,14"
                                              IsChecked="False"/>

                                <ToggleButton Content="Active setting"
                                              Style="{StaticResource NebulaToggleButton}"
                                              Margin="0,0,0,14"
                                              IsChecked="True"/>

                                <ToggleButton Content="Disabled setting"
                                              Style="{StaticResource NebulaToggleButton}"
                                              IsChecked="True"
                                              IsEnabled="False"/>
                            </StackPanel>
                        </Border>

                        <!-- ================================================== -->
                        <!-- ComboBox                                           -->
                        <!-- ================================================== -->
                        <Border Style="{StaticResource NebulaGalleryCard}">
                            <StackPanel>
                                <TextBlock Text="ComboBox"
                                           Style="{StaticResource GallerySectionTitleText}"/>

                                <TextBlock Text="Default selection"
                                           Style="{StaticResource GalleryLabelText}"/>
                                <controls:NebulaComboBox Style="{StaticResource NebulaComboBox}"
                                                         Width="300"
                                                         IsEditable="False"
                                                         SelectedIndex="0"
                                                         HorizontalAlignment="Left">
                                    <ComboBoxItem Content="Nebula Dark Purple"/>
                                    <ComboBoxItem Content="Midnight Gray"/>
                                    <ComboBoxItem Content="Soft Violet"/>
                                    <ComboBoxItem Content="Disabled option"
                                                  IsEnabled="False"/>
                                </controls:NebulaComboBox>

                                <TextBlock Text="Disabled state"
                                           Style="{StaticResource GalleryLabelText}"
                                           Margin="0,18,0,6"/>
                                <controls:NebulaComboBox Style="{StaticResource NebulaComboBox}"
                                                         Width="300"
                                                         SelectedIndex="0"
                                                         IsEnabled="False"
                                                         HorizontalAlignment="Left">
                                    <ComboBoxItem Content="Locked theme"/>
                                    <ComboBoxItem Content="Unavailable theme"/>
                                </controls:NebulaComboBox>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1">

                        <!-- ================================================== -->
                        <!-- Text inputs                                        -->
                        <!-- ================================================== -->
                        <Border Style="{StaticResource NebulaGalleryCard}">
                            <StackPanel>
                                <TextBlock Text="Text inputs"
                                           Style="{StaticResource GallerySectionTitleText}"/>

                                <TextBlock Text="TextBox"
                                           Style="{StaticResource GalleryLabelText}"/>
                                <TextBox Style="{StaticResource NebulaTextBox}"
                                         Text="Nebula text value"
                                         Width="300"
                                         HorizontalAlignment="Left"/>

                                <TextBlock Text="TextBox with integrated label"
                                           Style="{StaticResource GalleryLabelText}"
                                           Margin="0,18,0,6"/>

                                <controls:NebulaTextBox Style="{StaticResource NebulaLabeledTextBox}"
                                                        Label="Test Username"
                                                        Text="domin"
                                                        Width="300"
                                                        HorizontalAlignment="Left"/>

                                <controls:NebulaTextBox Style="{StaticResource NebulaLabeledTextBox}"
                                                        Label="Email: "
                                                        LabelPlacement="Left"
                                                        Text="hello@nebula.ui"
                                                        Width="300"
                                                        Margin="0,12,0,0"
                                                        HorizontalAlignment="Left"/>

                                <controls:NebulaTextBox Style="{StaticResource NebulaLabeledTextBox}"
                                                        Label="Disabled TextBox"
                                                        Text="NebulaLabeledTextBox"
                                                        Width="300"
                                                        Margin="0,12,0,0"
                                                        HorizontalAlignment="Left"
                                                        IsEnabled="False"/>

                                <TextBlock Text="PasswordBox"
                                           Style="{StaticResource GalleryLabelText}"
                                           Margin="0,18,0,6"/>
                                <PasswordBox Style="{StaticResource NebulaPasswordBox}"
                                             Password="nebula"
                                             Width="300"
                                             HorizontalAlignment="Left"/>

                                <controls:NebulaLabeledPasswordBox Style="{StaticResource NebulaLabeledPasswordBox}"
                                                                   Label="Password"
                                                                   Password="nebula"
                                                                   Width="300"
                                                                   Margin="0,12,0,0"
                                                                   HorizontalAlignment="Left"/>

                                <TextBlock Text="Readonly sample"
                                           Style="{StaticResource GalleryLabelText}"
                                           Margin="0,18,0,6"/>
                                <TextBox Style="{StaticResource NebulaTextBox}"
                                         Text="Locked field"
                                         Width="300"
                                         HorizontalAlignment="Left"
                                         IsReadOnly="True"/>
                            </StackPanel>
                        </Border>

                        <!-- ================================================== -->
                        <!-- RadioButton                                        -->
                        <!-- ================================================== -->
                        <Border Style="{StaticResource NebulaGalleryCard}">
                            <StackPanel>
                                <TextBlock Text="RadioButton"
                                           Style="{StaticResource GallerySectionTitleText}"/>

                                <RadioButton Content="First choice"
                                             GroupName="GalleryChoice"
                                             Style="{StaticResource NebulaRadioButton}"
                                             Margin="0,0,0,12"
                                             IsChecked="True"/>
                                <RadioButton Content="Second choice"
                                             GroupName="GalleryChoice"
                                             Style="{StaticResource NebulaRadioButton}"
                                             Margin="0,0,0,12"/>
                                <RadioButton Content="Disabled choice"
                                             GroupName="GalleryChoiceDisabled"
                                             Style="{StaticResource NebulaRadioButton}"
                                             IsChecked="True"
                                             IsEnabled="False"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- ================================================== -->
                <!-- Component state color                              -->
                <!-- ================================================== -->
                <Border Grid.Row="2"
                        Background="{DynamicResource Brush.Surface}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="22"
                        Margin="0,6,18,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Component states"
                                       Style="{StaticResource GallerySectionTitleText}"/>
                            <TextBlock Text="Use this window as a living preview while building new NebulaUI controls."
                                       Style="{StaticResource GallerySubtitleText}"/>
                        </StackPanel>

                        <WrapPanel Grid.Column="1"
                                   Margin="28,0,0,0"
                                   VerticalAlignment="Center">
                            <Border Background="{DynamicResource Brush.Success}"
                                    CornerRadius="4"
                                    Width="72"
                                    Height="34"
                                    Margin="0,0,8,0">
                                <TextBlock Text="Success"
                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <Border Background="{DynamicResource Brush.Warning}"
                                    CornerRadius="4"
                                    Width="72"
                                    Height="34"
                                    Margin="0,0,8,0">
                                <TextBlock Text="Warning"
                                           Foreground="{DynamicResource Brush.Background}"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <Border Background="{DynamicResource Brush.Danger}"
                                    CornerRadius="4"
                                    Width="72"
                                    Height="34"
                                    Margin="0,0,8,0">
                                <TextBlock Text="Danger"
                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <Border Background="{DynamicResource Brush.Info}"
                                    CornerRadius="4"
                                    Width="72"
                                    Height="34">
                                <TextBlock Text="Info"
                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </WrapPanel>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Border>
</Window>
