<!--
Nom: NebulaAlert
Version: V1.02
Description: Displays contextual feedback messages with info, success, warning and danger variants.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:NebulaControls.Controls">

    <Style x:Key="NebulaAlert"
           BasedOn="{StaticResource Typography.Text.Primary}"
           TargetType="controls:NebulaAlert">
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
        <Setter Property="Padding" Value="14"/>
        <Setter Property="Tag" Value="{DynamicResource Brush.BorderReadOnly}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:NebulaAlert">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="{TemplateBinding Tag}"
                                    CornerRadius="7,0,0,7"/>

                            <ContentPresenter Grid.Column="1"
                                              Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=controls:NebulaAlert}}"/>
                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NebulaPurpleAlert"
           BasedOn="{StaticResource NebulaAlert}"
           TargetType="controls:NebulaAlert">
        <Setter Property="Tag" Value="{DynamicResource Brush.Brand}"/>
    </Style>

    <Style x:Key="NebulaInfoAlert"
           BasedOn="{StaticResource NebulaAlert}"
           TargetType="controls:NebulaAlert">
        <Setter Property="Tag" Value="{DynamicResource Brush.Info}"/>
    </Style>

    <Style x:Key="NebulaSuccessAlert"
           BasedOn="{StaticResource NebulaAlert}"
           TargetType="controls:NebulaAlert">
        <Setter Property="Tag" Value="{DynamicResource Brush.Success}"/>
    </Style>

    <Style x:Key="NebulaWarningAlert"
           BasedOn="{StaticResource NebulaAlert}"
           TargetType="controls:NebulaAlert">
        <Setter Property="Tag" Value="{DynamicResource Brush.Warning}"/>
    </Style>

    <Style x:Key="NebulaDangerAlert"
           BasedOn="{StaticResource NebulaAlert}"
           TargetType="controls:NebulaAlert">
        <Setter Property="Tag" Value="{DynamicResource Brush.Danger}"/>
    </Style>

</ResourceDictionary>
