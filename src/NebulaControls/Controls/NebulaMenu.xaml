<!--
  Nom: NebulaMenu
  Version: V1.02
  Description: Defines Nebula menu and menu item styles for application menus.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/NebulaControls;component/Controls/NebulaContextMenu.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="NebulaMenuSeparator"
           BasedOn="{StaticResource NebulaContextMenuSeparator}"
           TargetType="Separator"/>

    <Style x:Key="NebulaMenuItem"
           BasedOn="{StaticResource Typography.Text.Primary}"
           TargetType="MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="MinWidth" Value="178"/>
        <Setter Property="MinHeight" Value="34"/>
        <Setter Property="ItemContainerStyle" Value="{DynamicResource NebulaMenuItem}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Grid>
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                MinHeight="{TemplateBinding MinHeight}"
                                SnapsToDevicePixels="True">
                            <Grid x:Name="ItemGrid"
                                  Margin="{TemplateBinding Padding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="IconColumn" Width="22"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition x:Name="GestureColumn" Width="Auto"/>
                                    <ColumnDefinition x:Name="GlyphColumn" Width="16"/>
                                </Grid.ColumnDefinitions>

                                <ContentPresenter x:Name="IconPresenter"
                                                  Grid.Column="0"
                                                  ContentSource="Icon"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"/>

                                <ContentPresenter Grid.Column="1"
                                                  ContentSource="Header"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>

                                <TextBlock x:Name="GestureText"
                                           Grid.Column="2"
                                           Text="{TemplateBinding InputGestureText}"
                                           Style="{StaticResource Typography.TextBlock.Muted}"
                                           Margin="18,0,0,0"
                                           VerticalAlignment="Center"/>

                                <Path x:Name="SubmenuGlyph"
                                      Grid.Column="3"
                                      Width="5"
                                      Height="9"
                                      Margin="10,0,0,0"
                                      Fill="{DynamicResource Brush.TextMuted}"
                                      Stretch="Fill"
                                      VerticalAlignment="Center"
                                      Data="M 0 0 L 5 4.5 L 0 9 Z"/>
                            </Grid>
                        </Border>

                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Focusable="False"
                               IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                               Placement="Bottom"
                               PopupAnimation="Fade">
                            <Border Background="{DynamicResource Brush.Surface}"
                                    BorderBrush="{DynamicResource Brush.Border}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="5"
                                    SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="18"
                                                      Direction="270"
                                                      Opacity="0.28"
                                                      ShadowDepth="6"
                                                      Color="#000000"/>
                                </Border.Effect>

                                <StackPanel IsItemsHost="True"
                                            KeyboardNavigation.DirectionalNavigation="Cycle"/>
                            </Border>
                        </Popup>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="Role" Value="TopLevelHeader">
                            <Setter Property="MinWidth" Value="0"/>
                            <Setter Property="Padding" Value="10,6"/>
                            <Setter TargetName="IconColumn" Property="Width" Value="0"/>
                            <Setter TargetName="GestureColumn" Property="Width" Value="0"/>
                            <Setter TargetName="GlyphColumn" Property="Width" Value="0"/>
                            <Setter TargetName="IconPresenter" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="GestureText" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="SubmenuGlyph" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="PART_Popup" Property="Placement" Value="Bottom"/>
                        </Trigger>

                        <Trigger Property="Role" Value="TopLevelItem">
                            <Setter Property="MinWidth" Value="0"/>
                            <Setter Property="Padding" Value="10,6"/>
                            <Setter TargetName="IconColumn" Property="Width" Value="0"/>
                            <Setter TargetName="GestureColumn" Property="Width" Value="0"/>
                            <Setter TargetName="GlyphColumn" Property="Width" Value="0"/>
                            <Setter TargetName="IconPresenter" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="GestureText" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="SubmenuGlyph" Property="Visibility" Value="Collapsed"/>
                        </Trigger>

                        <Trigger Property="Role" Value="SubmenuHeader">
                            <Setter TargetName="PART_Popup" Property="Placement" Value="Right"/>
                        </Trigger>

                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="IconPresenter" Property="Visibility" Value="Hidden"/>
                        </Trigger>

                        <Trigger Property="InputGestureText" Value="">
                            <Setter TargetName="GestureText" Property="Visibility" Value="Collapsed"/>
                        </Trigger>

                        <Trigger Property="HasItems" Value="False">
                            <Setter TargetName="SubmenuGlyph" Property="Visibility" Value="Collapsed"/>
                        </Trigger>

                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemBorder"
                                    Property="Background"
                                    Value="{DynamicResource Brush.SurfaceActive}"/>
                            <Setter TargetName="ItemBorder"
                                    Property="BorderBrush"
                                    Value="Transparent"/>
                        </Trigger>

                        <Trigger Property="IsSubmenuOpen" Value="True">
                            <Setter TargetName="ItemBorder"
                                    Property="Background"
                                    Value="{DynamicResource Brush.SurfaceActive}"/>
                            <Setter TargetName="ItemBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource Brush.BorderReadOnly}"/>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Brush.TextDisabled}"/>
                            <Setter TargetName="GestureText"
                                    Property="Foreground"
                                    Value="{DynamicResource Brush.TextDisabled}"/>
                            <Setter TargetName="SubmenuGlyph"
                                    Property="Fill"
                                    Value="{DynamicResource Brush.TextDisabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NebulaMenu"
           TargetType="Menu">
        <Setter Property="Background" Value="{DynamicResource Brush.SurfaceReadOnly}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="5"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource NebulaMenuItem}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Menu">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ItemsPresenter KeyboardNavigation.TabNavigation="Cycle"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NebulaWindowMenu"
           BasedOn="{StaticResource NebulaMenu}"
           TargetType="Menu">
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Menu">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ItemsPresenter KeyboardNavigation.TabNavigation="Cycle"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
