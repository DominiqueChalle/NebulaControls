<!--
  Nom: NebulaNumericUpDown
  Version: V1.02
  Description: Numeric input control with increment, decrement and range clamping behavior.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:NebulaControls.Controls">

    <Style x:Key="NebulaNumericUpDownTextBox"
           BasedOn="{StaticResource Typography.Text.Primary}"
           TargetType="TextBox">
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="CaretBrush" Value="{DynamicResource Brush.Brand}"/>
        <Setter Property="SelectionBrush" Value="{DynamicResource Brush.BrandHover}"/>
        <Setter Property="SelectionOpacity" Value="0.5"/>
        <Setter Property="Padding" Value="10,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <ScrollViewer x:Name="PART_ContentHost"
                                  Margin="{TemplateBinding Padding}"
                                  VerticalAlignment="Center"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NebulaNumericUpDownButton"
           TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize.Caption}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder"
                                    Property="Background"
                                    Value="{DynamicResource Brush.SurfaceHover}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Brush.BrandSoft}"/>
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder"
                                    Property="Background"
                                    Value="{DynamicResource Brush.SurfaceActive}"/>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Brush.TextDisabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NebulaNumericUpDown"
           BasedOn="{StaticResource Typography.Text.Primary}"
           TargetType="controls:NebulaNumericUpDown">
        <Setter Property="Background" Value="{DynamicResource Brush.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
        <Setter Property="BorderThickness" Value="0,0,0,2"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
        <Setter Property="MinHeight" Value="34"/>
        <Setter Property="Width" Value="180"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:NebulaNumericUpDown">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            MinHeight="{TemplateBinding MinHeight}"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="34"/>
                            </Grid.ColumnDefinitions>

                            <Grid>
                                <TextBox x:Name="PART_TextBox"
                                         Style="{StaticResource NebulaNumericUpDownTextBox}"
                                         Foreground="{TemplateBinding Foreground}"
                                         IsReadOnly="{TemplateBinding IsReadOnly}"/>

                                <TextBlock x:Name="PlaceholderText"
                                           Text="{TemplateBinding Placeholder}"
                                           Style="{StaticResource Typography.TextBlock.Muted}"
                                           Margin="20,0,0,0"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed"/>
                            </Grid>

                            <Border Grid.Column="1"
                                    Width="1"
                                    HorizontalAlignment="Left"
                                    Background="{DynamicResource Brush.Border}"
                                    Margin="0,6"/>

                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Button Grid.Row="0"
                                        Content="+"
                                        Command="{Binding IncreaseCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                        Style="{StaticResource NebulaNumericUpDownButton}"/>
                                <Button Grid.Row="1"
                                        Content="-"
                                        Command="{Binding DecreaseCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                        Style="{StaticResource NebulaNumericUpDownButton}"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding Text, ElementName=PART_TextBox}" Value="">
                            <Setter TargetName="PlaceholderText"
                                    Property="Visibility"
                                    Value="Visible"/>
                        </DataTrigger>

                        <Trigger Property="Placeholder" Value="">
                            <Setter TargetName="PlaceholderText"
                                    Property="Visibility"
                                    Value="Collapsed"/>
                        </Trigger>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border"
                                    Property="Background"
                                    Value="{DynamicResource Brush.SurfaceHover}"/>
                            <Setter TargetName="Border"
                                    Property="BorderBrush"
                                    Value="{DynamicResource Brush.Brand}"/>
                        </Trigger>

                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Border"
                                    Property="BorderBrush"
                                    Value="{DynamicResource Brush.BrandHover}"/>
                        </Trigger>

                        <Trigger Property="IsReadOnly" Value="True">
                            <Setter TargetName="Border"
                                    Property="Background"
                                    Value="{DynamicResource Brush.BackgroundReadOnly}"/>
                            <Setter TargetName="Border"
                                    Property="BorderBrush"
                                    Value="{DynamicResource Brush.BorderReadOnly}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Brush.TextSecondary}"/>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Border"
                                    Property="Background"
                                    Value="{DynamicResource Brush.BackgroundDisabled}"/>
                            <Setter TargetName="Border"
                                    Property="BorderBrush"
                                    Value="{DynamicResource Brush.BorderDisabled}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Brush.TextDisabled}"/>
                            <Setter TargetName="PlaceholderText"
                                    Property="Foreground"
                                    Value="{DynamicResource Brush.TextDisabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource NebulaNumericUpDown}"
           TargetType="controls:NebulaNumericUpDown"/>

</ResourceDictionary>
