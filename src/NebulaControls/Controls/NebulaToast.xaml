<!--
Nom: NebulaToast
Version: V1.04
Description: Toast notification control for temporary application feedback.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:NebulaControls.Controls">

    <Style x:Key="NebulaToastCloseButton"
           TargetType="Button">
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                        <TextBlock Text="&#xE711;"
                                   FontFamily="{StaticResource Font.Icon}"
                                   FontSize="{StaticResource FontSize.IconSmall}"
                                   Foreground="{TemplateBinding Foreground}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder"
                                    Property="Background"
                                    Value="{DynamicResource Brush.SurfaceHover}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Brush.TextPrimary}"/>
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder"
                                    Property="Background"
                                    Value="{DynamicResource Brush.SurfaceActive}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NebulaToast"
           BasedOn="{StaticResource Typography.Text.Primary}"
           TargetType="controls:NebulaToast">
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
        <Setter Property="Padding" Value="14"/>
        <Setter Property="MinWidth" Value="340"/>
        <Setter Property="MaxWidth" Value="420"/>
        <Setter Property="Width" Value="380"/>
        <Setter Property="Tag" Value="{DynamicResource Brush.Info}"/>
        <Setter Property="Icon" Value="&#xE946;"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:NebulaToast">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="{TemplateBinding Tag}"
                                    CornerRadius="9,0,0,9"/>

                            <Border Grid.Column="1"
                                    Width="32"
                                    Height="32"
                                    Background="{TemplateBinding Tag}"
                                    CornerRadius="16"
                                    Margin="14,14,0,14"
                                    VerticalAlignment="Top">
                                <TextBlock Text="{TemplateBinding Icon}"
                                           FontFamily="Segoe UI"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource Brush.TextOnAccent}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="2"
                                        Margin="{TemplateBinding Padding}">
                                <TextBlock Text="{TemplateBinding Title}"
                                           Style="{StaticResource Typography.TextBlock.Strong}"/>
                                <TextBlock Text="{TemplateBinding Message}"
                                           Foreground="{TemplateBinding Foreground}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <Button Grid.Column="3"
                                    Command="{Binding CloseCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                    Style="{StaticResource NebulaToastCloseButton}"
                                    Margin="0,8,8,0"
                                    VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NebulaInfoToast"
           BasedOn="{StaticResource NebulaToast}"
           TargetType="controls:NebulaToast">
        <Setter Property="Tag" Value="{DynamicResource Brush.Info}"/>
        <Setter Property="Icon" Value="i"/>
    </Style>

    <Style x:Key="NebulaSuccessToast"
           BasedOn="{StaticResource NebulaToast}"
           TargetType="controls:NebulaToast">
        <Setter Property="Tag" Value="{DynamicResource Brush.Success}"/>
        <Setter Property="Icon" Value="&#x2713;"/>
    </Style>

    <Style x:Key="NebulaWarningToast"
           BasedOn="{StaticResource NebulaToast}"
           TargetType="controls:NebulaToast">
        <Setter Property="Tag" Value="{DynamicResource Brush.Warning}"/>
        <Setter Property="Icon" Value="!"/>
    </Style>

    <Style x:Key="NebulaDangerToast"
           BasedOn="{StaticResource NebulaToast}"
           TargetType="controls:NebulaToast">
        <Setter Property="Tag" Value="{DynamicResource Brush.Danger}"/>
        <Setter Property="Icon" Value="&#x00D7;"/>
    </Style>

    <Style BasedOn="{StaticResource NebulaToast}"
           TargetType="controls:NebulaToast"/>

    <Style x:Key="NebulaToastHost"
           TargetType="controls:NebulaToastHost">
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="VerticalAlignment" Value="Bottom"/>
        <Setter Property="Margin" Value="0,0,28,28"/>
        <Setter Property="MaxToasts" Value="4"/>
        <Setter Property="ToastDuration" Value="0:0:5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:NebulaToastHost">
                    <Border Background="Transparent">
                        <ItemsPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel/>
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemTemplate">
            <Setter.Value>
                <DataTemplate>
                    <controls:NebulaToast x:Name="ToastControl"
                                          Style="{Binding Style}"
                                          Title="{Binding Title}"
                                          Message="{Binding Message}"
                                          Margin="0,0,0,10"
                                          Opacity="0"
                                          CloseRequestedCommand="{Binding CloseToastCommand, RelativeSource={RelativeSource AncestorType=controls:NebulaToastHost}}"
                                          CloseRequestedCommandParameter="{Binding}">
                        <controls:NebulaToast.RenderTransform>
                            <TranslateTransform x:Name="ToastTransform" Y="24"/>
                        </controls:NebulaToast.RenderTransform>
                    </controls:NebulaToast>

                    <DataTemplate.Triggers>
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="ToastTransform"
                                                     Storyboard.TargetProperty="Y"
                                                     To="0"
                                                     Duration="0:0:0.22">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="ToastControl"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="1"
                                                     Duration="0:0:0.22"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource NebulaToastHost}"
           TargetType="controls:NebulaToastHost"/>

</ResourceDictionary>
