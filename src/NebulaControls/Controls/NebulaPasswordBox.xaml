<!--
  Nom: NebulaPasswordBox
  Version: V1.03
  Description: Defines Nebula password input styles including labeled password input support.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:NebulaControls.Controls">

    <Style x:Key="NebulaPasswordBoxBase" BasedOn="{StaticResource Typography.Text.Primary}"
           TargetType="PasswordBox">

        <Setter Property="Background" Value="{DynamicResource Brush.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
        <Setter Property="SelectionBrush" Value="{DynamicResource Brush.BrandHover}" />
        <Setter Property="CaretBrush" Value="{DynamicResource Brush.Brand}" />
        <Setter Property="SelectionOpacity" Value="0.5" />
        <Setter Property="BorderThickness" Value="0,0,0,2"/>
        <Setter Property="Padding" Value="8,0"/>
        <Setter Property="MinHeight" Value="34"/>
        <Setter Property="controls:NebulaInputFocus.SelectAllOnFocus" Value="True"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            MinHeight="{TemplateBinding MinHeight}">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource Brush.SurfaceHover}"/>
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource Brush.Brand}"/>
                        </Trigger>

                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource Brush.BrandHover}"/>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource Brush.BackgroundDisabled}"/>
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource Brush.BorderDisabled}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Brush.TextDisabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NebulaSmallPasswordBox"
           BasedOn="{StaticResource NebulaPasswordBoxBase}"
           TargetType="PasswordBox">
        <Setter Property="Padding" Value="6,0"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="MinHeight" Value="24"/>
    </Style>

    <Style x:Key="NebulaMediumPasswordBox"
           BasedOn="{StaticResource NebulaPasswordBoxBase}"
           TargetType="PasswordBox">
        <Setter Property="Padding" Value="8,0"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="MinHeight" Value="34"/>
    </Style>

    <Style x:Key="NebulaPasswordBox"
           BasedOn="{StaticResource NebulaMediumPasswordBox}"
           TargetType="PasswordBox"/>

    <Style x:Key="NebulaLargePasswordBox"
           BasedOn="{StaticResource NebulaPasswordBoxBase}"
           TargetType="PasswordBox">
        <Setter Property="Padding" Value="10,0"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="Height" Value="46"/>
        <Setter Property="MinHeight" Value="46"/>
    </Style>

    <Style x:Key="NebulaPasswordRevealButton" TargetType="Button">
        <Setter Property="Width" Value="48"/>
        <Setter Property="Height" Value="26"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0,0,6,0"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize.Caption}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Brush.SurfaceHover}"/>
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Brush.SurfaceActive}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NebulaLabeledPasswordBox"
           BasedOn="{StaticResource Typography.Text.Primary}"
           TargetType="controls:NebulaLabeledPasswordBox">

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:NebulaLabeledPasswordBox">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DockPanel LastChildFill="True">
                            <TextBlock x:Name="LabelText"
                                       DockPanel.Dock="{TemplateBinding LabelPlacement}"
                                       Text="{TemplateBinding Label}"
                                       Style="{StaticResource Typography.TextBlock.Caption}"
                                       Margin="0,0,0,6"/>

                            <Grid>
                                <PasswordBox x:Name="PART_PasswordBox"
                                             Style="{StaticResource NebulaPasswordBox}"
                                             Padding="8,0,58,0"/>
                                <TextBox x:Name="PART_RevealedTextBox"
                                         Style="{DynamicResource NebulaTextBox}"
                                         Padding="8,0,58,0"
                                         Visibility="Collapsed"/>
                                <Button x:Name="PART_RevealButton"
                                        Style="{StaticResource NebulaPasswordRevealButton}"
                                        Content="Show"/>
                            </Grid>
                        </DockPanel>

                        <TextBlock x:Name="HelperTextBlock"
                                   Grid.Row="1"
                                   Text="{TemplateBinding HelperText}"
                                   Style="{StaticResource Typography.TextBlock.Caption}"
                                   Margin="0,6,0,0"/>

                        <TextBlock x:Name="ErrorTextBlock"
                                   Grid.Row="1"
                                   Text="{TemplateBinding ErrorText}"
                                   Style="{StaticResource Typography.TextBlock.Danger}"
                                   Margin="0,6,0,0"
                                   Visibility="Collapsed"/>

                        <TextBlock x:Name="WarningTextBlock"
                                   Grid.Row="1"
                                   Text="{TemplateBinding WarningText}"
                                   Style="{StaticResource Typography.TextBlock.Warning}"
                                   Margin="0,6,0,0"
                                   Visibility="Collapsed"/>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="Label" Value="">
                            <Setter TargetName="LabelText" Property="Visibility" Value="Collapsed"/>
                        </Trigger>

                        <Trigger Property="HelperText" Value="">
                            <Setter TargetName="HelperTextBlock" Property="Visibility" Value="Collapsed"/>
                        </Trigger>

                        <Trigger Property="WarningText" Value="">
                            <Setter TargetName="WarningTextBlock" Property="Visibility" Value="Collapsed"/>
                        </Trigger>

                        <Trigger Property="LabelPlacement" Value="Left">
                            <Setter TargetName="LabelText" Property="Margin" Value="0,0,5,0"/>
                            <Setter TargetName="LabelText" Property="VerticalAlignment" Value="Center"/>
                        </Trigger>

                        <Trigger Property="LabelPlacement" Value="Right">
                            <Setter TargetName="LabelText" Property="Margin" Value="10,0,0,0"/>
                            <Setter TargetName="LabelText" Property="VerticalAlignment" Value="Center"/>
                        </Trigger>

                        <Trigger Property="LabelPlacement" Value="Bottom">
                            <Setter TargetName="LabelText" Property="Margin" Value="0,6,0,0"/>
                        </Trigger>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_PasswordBox" Property="Background" Value="{DynamicResource Brush.SurfaceHover}"/>
                            <Setter TargetName="PART_PasswordBox" Property="BorderBrush" Value="{DynamicResource Brush.Brand}"/>
                            <Setter TargetName="PART_RevealedTextBox" Property="Background" Value="{DynamicResource Brush.SurfaceHover}"/>
                            <Setter TargetName="PART_RevealedTextBox" Property="BorderBrush" Value="{DynamicResource Brush.Brand}"/>
                        </Trigger>

                        <Trigger SourceName="PART_PasswordBox" Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="PART_PasswordBox" Property="BorderBrush" Value="{DynamicResource Brush.BrandHover}"/>
                            <Setter TargetName="LabelText" Property="Foreground" Value="{DynamicResource Brush.BrandSoft}"/>
                        </Trigger>

                        <Trigger SourceName="PART_RevealedTextBox" Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="PART_RevealedTextBox" Property="BorderBrush" Value="{DynamicResource Brush.BrandHover}"/>
                            <Setter TargetName="LabelText" Property="Foreground" Value="{DynamicResource Brush.BrandSoft}"/>
                        </Trigger>

                        <Trigger Property="HasWarning" Value="True">
                            <Setter TargetName="PART_PasswordBox" Property="BorderBrush" Value="{DynamicResource Brush.Warning}"/>
                            <Setter TargetName="PART_RevealedTextBox" Property="BorderBrush" Value="{DynamicResource Brush.Warning}"/>
                            <Setter TargetName="LabelText" Property="Foreground" Value="{DynamicResource Brush.Warning}"/>
                            <Setter TargetName="HelperTextBlock" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="WarningTextBlock" Property="Visibility" Value="Visible"/>
                        </Trigger>

                        <Trigger Property="HasError" Value="True">
                            <Setter TargetName="PART_PasswordBox" Property="BorderBrush" Value="{DynamicResource Brush.Danger}"/>
                            <Setter TargetName="PART_RevealedTextBox" Property="BorderBrush" Value="{DynamicResource Brush.Danger}"/>
                            <Setter TargetName="LabelText" Property="Foreground" Value="{DynamicResource Brush.Danger}"/>
                            <Setter TargetName="HelperTextBlock" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="WarningTextBlock" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="ErrorTextBlock" Property="Visibility" Value="Visible"/>
                        </Trigger>

                        <Trigger Property="ErrorText" Value="">
                            <Setter TargetName="ErrorTextBlock" Property="Visibility" Value="Collapsed"/>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="PART_PasswordBox" Property="Background" Value="{DynamicResource Brush.BackgroundDisabled}"/>
                            <Setter TargetName="PART_PasswordBox" Property="BorderBrush" Value="{DynamicResource Brush.BorderDisabled}"/>
                            <Setter TargetName="PART_RevealedTextBox" Property="Background" Value="{DynamicResource Brush.BackgroundDisabled}"/>
                            <Setter TargetName="PART_RevealedTextBox" Property="BorderBrush" Value="{DynamicResource Brush.BorderDisabled}"/>
                            <Setter TargetName="PART_RevealButton" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="LabelText" Property="Foreground" Value="{DynamicResource Brush.TextDisabled}"/>
                            <Setter TargetName="HelperTextBlock" Property="Foreground" Value="{DynamicResource Brush.TextDisabled}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Brush.TextDisabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
