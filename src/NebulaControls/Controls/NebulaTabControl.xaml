<!--
  Nom: NebulaTabControl
  Version: V1.02
  Description: Top-only tab control for switching between related content pages.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:NebulaControls.Controls">

    <Style x:Key="NebulaTabItem"
           BasedOn="{StaticResource Typography.Text.Primary}"
           TargetType="controls:NebulaTabItem">
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="17,7,16,7"/>
        <Setter Property="Margin" Value="0,0,-5,0"/>
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="MinWidth" Value="92"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Panel.ZIndex" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:NebulaTabItem">
                    <Grid SnapsToDevicePixels="True"
                          MinHeight="{TemplateBinding MinHeight}"
                          MinWidth="{TemplateBinding MinWidth}">
                        <Border x:Name="TabShape"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6,6,0,0"
                                Margin="0"/>
                        <Border Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="TabShape"
                                    Property="Background"
                                    Value="{DynamicResource Brush.SurfaceHover}"/>
                            <Setter TargetName="TabShape"
                                    Property="BorderBrush"
                                    Value="{DynamicResource Brush.BorderHover}"/>
                            <Setter Property="Panel.ZIndex"
                                    Value="5"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Brush.TextPrimary}"/>
                        </Trigger>

                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="TabShape"
                                    Property="Background"
                                    Value="{DynamicResource Brush.Surface}"/>
                            <Setter TargetName="TabShape"
                                    Property="BorderBrush"
                                    Value="{DynamicResource Brush.BrandSoft}"/>
                            <Setter Property="Panel.ZIndex"
                                    Value="10"/>
                            <Setter Property="Margin"
                                    Value="0,0,-5,-2"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Brush.TextPrimary}"/>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Brush.TextDisabled}"/>
                            <Setter TargetName="TabShape"
                                    Property="Background"
                                    Value="{DynamicResource Brush.SurfaceDisabled}"/>
                            <Setter TargetName="TabShape"
                                    Property="BorderBrush"
                                    Value="{DynamicResource Brush.BorderDisabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NebulaTabControl"
           BasedOn="{StaticResource Typography.Text.Primary}"
           TargetType="controls:NebulaTabControl">
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="SelectedIndex" Value="0"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource NebulaTabItem}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:NebulaTabControl">
                    <Grid x:Name="Root"
                          SnapsToDevicePixels="True">
                        <Grid.RowDefinitions>
                            <RowDefinition x:Name="FirstRow"
                                           Height="Auto"/>
                            <RowDefinition x:Name="SecondRow"
                                           Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="FirstColumn"
                                              Width="Auto"/>
                            <ColumnDefinition x:Name="SecondColumn"
                                              Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TabPanel x:Name="HeaderPanel"
                                  Grid.Row="0"
                                  Grid.Column="1"
                                  Margin="0"
                                  Panel.ZIndex="1"
                                  IsItemsHost="True"
                                  KeyboardNavigation.TabIndex="1"/>

                        <Border x:Name="ContentBorder"
                                Grid.Row="1"
                                Grid.Column="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              ContentSource="SelectedContent"
                                              Margin="14"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Brush.TextDisabled}"/>
                            <Setter TargetName="ContentBorder"
                                    Property="Background"
                                    Value="{DynamicResource Brush.SurfaceDisabled}"/>
                            <Setter TargetName="ContentBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource Brush.BorderDisabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
