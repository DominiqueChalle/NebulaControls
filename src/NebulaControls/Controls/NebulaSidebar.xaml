<!--
Nom: NebulaSidebar
Version: V1.00
Description: Collapsible sidebar navigation styles with icon and text items.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:NebulaControls.Controls">

    <Style x:Key="NebulaSidebarToggleButton"
           TargetType="ToggleButton">
        <Setter Property="Width" Value="34"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <Viewbox Width="22"
                                 Height="22"
                                 Stretch="Uniform"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center">
                            <Canvas Width="16"
                                    Height="16">
                                <Path Data="M 3 1.5 H 13 C 13.85 1.5 14.5 2.15 14.5 3 V 13 C 14.5 13.85 13.85 14.5 13 14.5 H 3 C 2.15 14.5 1.5 13.85 1.5 13 V 3 C 1.5 2.15 2.15 1.5 3 1.5 Z"
                                      Stroke="{TemplateBinding Foreground}"
                                      StrokeThickness="1"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Fill="Transparent"/>
                                <Path Data="M 6.3 1.5 V 14.5"
                                      Stroke="{TemplateBinding Foreground}"
                                      StrokeThickness="1"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"/>
                                <Path x:Name="ToggleIcon"
                                      Data="M 4.7 5.7 L 3.05 8 L 4.7 10.3"
                                      Stroke="{TemplateBinding Foreground}"
                                      StrokeThickness="1.25"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Fill="Transparent"/>
                            </Canvas>
                        </Viewbox>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder"
                                    Property="Background"
                                    Value="{DynamicResource Brush.SurfaceHover}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Brush.TextPrimary}"/>
                        </Trigger>

                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="ButtonBorder"
                                    Property="Background"
                                    Value="{DynamicResource Brush.SurfaceActive}"/>
                            <Setter TargetName="ToggleIcon"
                                    Property="Data"
                                    Value="M 3.35 5.7 L 5 8 L 3.35 10.3"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NebulaSidebarItem"
           BasedOn="{StaticResource Typography.Text.Primary}"
           TargetType="controls:NebulaSidebarItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="MinWidth" Value="0"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="Padding" Value="14,9"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.BrandSoft}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="ToolTip" Value="{Binding Content, RelativeSource={RelativeSource Self}}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:NebulaSidebarItem">
                    <Border x:Name="ItemBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <StackPanel x:Name="ItemPanel"
                                    Orientation="Horizontal">
                            <TextBlock x:Name="IconText"
                                       Text="{TemplateBinding Icon}"
                                       FontFamily="{StaticResource Font.Icon}"
                                       FontSize="15"
                                       Width="22"
                                       Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <ContentPresenter x:Name="TextPresenter"
                                              Content="{TemplateBinding Content}"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </StackPanel>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ItemBorder"
                                    Property="Background"
                                    Value="{DynamicResource Brush.SurfaceHover}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Brush.TextPrimary}"/>
                        </Trigger>

                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemBorder"
                                    Property="Background"
                                    Value="{DynamicResource Brush.SurfaceActive}"/>
                            <Setter TargetName="ItemBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource Brush.BorderFocus}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Brush.TextPrimary}"/>
                        </Trigger>

                        <DataTrigger Binding="{Binding IsCollapsed, RelativeSource={RelativeSource AncestorType=controls:NebulaSidebar}}" Value="True">
                            <Setter Property="Width" Value="40"/>
                            <Setter Property="Height" Value="36"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter TargetName="ItemPanel"
                                    Property="HorizontalAlignment"
                                    Value="Center"/>
                            <Setter TargetName="ItemPanel"
                                    Property="VerticalAlignment"
                                    Value="Center"/>
                            <Setter TargetName="TextPresenter"
                                    Property="Visibility"
                                    Value="Collapsed"/>
                            <Setter TargetName="IconText"
                                    Property="FontSize"
                                    Value="18"/>
                            <Setter TargetName="IconText"
                                    Property="Width"
                                    Value="28"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NebulaSidebar"
           BasedOn="{StaticResource Typography.Text.Primary}"
           TargetType="controls:NebulaSidebar">
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
        <Setter Property="Padding" Value="24,20,18,24"/>
        <Setter Property="Width" Value="{Binding ExpandedWidth, RelativeSource={RelativeSource Self}}"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource NebulaSidebarItem}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:NebulaSidebar">
                    <Border x:Name="SidebarBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <StackPanel>
                            <Grid>
                                <TextBlock x:Name="TitleText"
                                           Text="{TemplateBinding Title}"
                                           Style="{StaticResource Typography.TextBlock.SectionTitle}"
                                           VerticalAlignment="Center"/>
                                <ToggleButton x:Name="ToggleButton"
                                              Style="{StaticResource NebulaSidebarToggleButton}"
                                              IsChecked="{Binding IsCollapsed, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                            </Grid>

                            <TextBlock x:Name="DescriptionText"
                                       Text="{TemplateBinding Description}"
                                       Style="{StaticResource Typography.TextBlock.Secondary}"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,24"/>

                            <ScrollViewer x:Name="ItemsScrollViewer"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto"
                                          Focusable="False"
                                          Margin="0,4,0,0">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsCollapsed" Value="True">
                            <Setter Property="Width"
                                    Value="{Binding CollapsedWidth, RelativeSource={RelativeSource Self}}"/>
                            <Setter Property="Padding"
                                    Value="12,20,12,24"/>
                            <Setter TargetName="TitleText"
                                    Property="Visibility"
                                    Value="Collapsed"/>
                            <Setter TargetName="DescriptionText"
                                    Property="Visibility"
                                    Value="Collapsed"/>
                            <Setter TargetName="ToggleButton"
                                    Property="HorizontalAlignment"
                                    Value="Center"/>
                            <Setter TargetName="ItemsScrollViewer"
                                    Property="Margin"
                                    Value="0,14,0,0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource NebulaSidebar}"
           TargetType="controls:NebulaSidebar"/>

</ResourceDictionary>
