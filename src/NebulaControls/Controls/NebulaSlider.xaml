<!--
  Nom: NebulaSlider
  Version: V1.02
  Description: Defines Nebula slider styling for continuous numeric selection.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:NebulaControls.Controls">

    <Style x:Key="NebulaSliderTrackButton"
           TargetType="RepeatButton">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="4"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NebulaSliderThumb"
           TargetType="Thumb">
        <Setter Property="Width" Value="18"/>
        <Setter Property="Height" Value="18"/>
        <Setter Property="Background" Value="{DynamicResource Brush.Brand}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.BrandSoft}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="ThumbBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="9"/>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbBorder"
                                    Property="Background"
                                    Value="{DynamicResource Brush.BrandHover}"/>
                            <Setter TargetName="ThumbBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource Brush.BrandLight}"/>
                        </Trigger>

                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbBorder"
                                    Property="Background"
                                    Value="{DynamicResource Brush.BrandPressed}"/>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ThumbBorder"
                                    Property="Background"
                                    Value="{DynamicResource Brush.AccentDisabled}"/>
                            <Setter TargetName="ThumbBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource Brush.AccentBorderDisabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NebulaSlider"
           BasedOn="{StaticResource Typography.Text.Primary}"
           TargetType="controls:NebulaSlider">
        <Setter Property="Foreground" Value="{DynamicResource Brush.AccentDisabled}"/>
        <Setter Property="Background" Value="{DynamicResource Brush.SurfaceActive}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="MinWidth" Value="120"/>
        <Setter Property="TickPlacement" Value="None"/>
        <Setter Property="IsSnapToTickEnabled" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:NebulaSlider">
                    <Grid x:Name="Root"
                          MinHeight="{TemplateBinding MinHeight}"
                          MinWidth="{TemplateBinding MinWidth}"
                          SnapsToDevicePixels="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="8"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                        </Grid.ColumnDefinitions>

                        <TickBar x:Name="TopTick"
                                 Grid.Row="0"
                                 Grid.ColumnSpan="3"
                                 Height="8"
                                 Margin="0"
                                 Fill="{DynamicResource Brush.BorderReadOnly}"
                                 Minimum="{TemplateBinding Minimum}"
                                 Maximum="{TemplateBinding Maximum}"
                                 TickFrequency="{TemplateBinding TickFrequency}"
                                 Ticks="{TemplateBinding Ticks}"
                                 ReservedSpace="{Binding ActualWidth, ElementName=SliderThumb}"
                                 Placement="Top"
                                 Visibility="Collapsed"/>

                        <Track x:Name="PART_Track"
                               Grid.Row="1"
                               Grid.ColumnSpan="3"
                               Height="8"
                               VerticalAlignment="Center">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Background="{TemplateBinding Foreground}"
                                              Command="Slider.DecreaseLarge"
                                              Style="{StaticResource NebulaSliderTrackButton}"/>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb x:Name="SliderThumb"
                                       Style="{StaticResource NebulaSliderThumb}"
                                       Margin="-1,-5"/>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Background="{TemplateBinding Background}"
                                              Command="Slider.IncreaseLarge"
                                              Style="{StaticResource NebulaSliderTrackButton}"/>
                            </Track.IncreaseRepeatButton>
                        </Track>

                        <TickBar x:Name="BottomTick"
                                 Grid.Row="2"
                                 Grid.ColumnSpan="3"
                                 Height="8"
                                 Margin="0"
                                 Fill="{DynamicResource Brush.BorderReadOnly}"
                                 Minimum="{TemplateBinding Minimum}"
                                 Maximum="{TemplateBinding Maximum}"
                                 TickFrequency="{TemplateBinding TickFrequency}"
                                 Ticks="{TemplateBinding Ticks}"
                                 ReservedSpace="{Binding ActualWidth, ElementName=SliderThumb}"
                                 Placement="Bottom"
                                 Visibility="Collapsed"/>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter Property="BorderBrush"
                                    Value="{DynamicResource Brush.BorderFocus}"/>
                        </Trigger>

                        <Trigger Property="TickPlacement" Value="TopLeft">
                            <Setter TargetName="TopTick"
                                    Property="Visibility"
                                    Value="Visible"/>
                            <Setter Property="IsSnapToTickEnabled"
                                    Value="True"/>
                        </Trigger>

                        <Trigger Property="TickPlacement" Value="BottomRight">
                            <Setter TargetName="BottomTick"
                                    Property="Visibility"
                                    Value="Visible"/>
                            <Setter Property="IsSnapToTickEnabled"
                                    Value="True"/>
                        </Trigger>

                        <Trigger Property="TickPlacement" Value="Both">
                            <Setter TargetName="TopTick"
                                    Property="Visibility"
                                    Value="Visible"/>
                            <Setter TargetName="BottomTick"
                                    Property="Visibility"
                                    Value="Visible"/>
                            <Setter Property="IsSnapToTickEnabled"
                                    Value="True"/>
                        </Trigger>

                        <Trigger Property="Orientation" Value="Vertical">
                            <Setter Property="MinWidth"
                                    Value="36"/>
                            <Setter Property="MinHeight"
                                    Value="120"/>
                            <Setter TargetName="Root"
                                    Property="MinHeight"
                                    Value="120"/>
                            <Setter TargetName="Root"
                                    Property="MinWidth"
                                    Value="36"/>
                            <Setter TargetName="PART_Track"
                                    Property="Grid.Row"
                                    Value="0"/>
                            <Setter TargetName="PART_Track"
                                    Property="Grid.RowSpan"
                                    Value="3"/>
                            <Setter TargetName="PART_Track"
                                    Property="Grid.Column"
                                    Value="1"/>
                            <Setter TargetName="PART_Track"
                                    Property="Grid.ColumnSpan"
                                    Value="1"/>
                            <Setter TargetName="PART_Track"
                                    Property="Width"
                                    Value="8"/>
                            <Setter TargetName="PART_Track"
                                    Property="Height"
                                    Value="Auto"/>
                            <Setter TargetName="PART_Track"
                                    Property="HorizontalAlignment"
                                    Value="Center"/>
                            <Setter TargetName="PART_Track"
                                    Property="VerticalAlignment"
                                    Value="Stretch"/>
                            <Setter TargetName="PART_Track"
                                    Property="Orientation"
                                    Value="Vertical"/>
                            <Setter TargetName="PART_Track"
                                    Property="IsDirectionReversed"
                                    Value="False"/>
                            <Setter TargetName="SliderThumb"
                                    Property="Margin"
                                    Value="-5,-1"/>
                            <Setter TargetName="TopTick"
                                    Property="Grid.Row"
                                    Value="0"/>
                            <Setter TargetName="TopTick"
                                    Property="Grid.RowSpan"
                                    Value="3"/>
                            <Setter TargetName="TopTick"
                                    Property="Grid.Column"
                                    Value="0"/>
                            <Setter TargetName="TopTick"
                                    Property="Grid.ColumnSpan"
                                    Value="1"/>
                            <Setter TargetName="TopTick"
                                    Property="Placement"
                                    Value="Left"/>
                            <Setter TargetName="TopTick"
                                    Property="Width"
                                    Value="5"/>
                            <Setter TargetName="TopTick"
                                    Property="Height"
                                    Value="Auto"/>
                            <Setter TargetName="TopTick"
                                    Property="Margin"
                                    Value="0,0,1,0"/>
                            <Setter TargetName="TopTick"
                                    Property="ReservedSpace">
                                <Setter.Value>
                                    <Binding ElementName="SliderThumb" Path="ActualHeight"/>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="BottomTick"
                                    Property="Grid.Row"
                                    Value="0"/>
                            <Setter TargetName="BottomTick"
                                    Property="Grid.RowSpan"
                                    Value="3"/>
                            <Setter TargetName="BottomTick"
                                    Property="Grid.Column"
                                    Value="2"/>
                            <Setter TargetName="BottomTick"
                                    Property="Grid.ColumnSpan"
                                    Value="1"/>
                            <Setter TargetName="BottomTick"
                                    Property="Placement"
                                    Value="Right"/>
                            <Setter TargetName="BottomTick"
                                    Property="Width"
                                    Value="5"/>
                            <Setter TargetName="BottomTick"
                                    Property="Height"
                                    Value="Auto"/>
                            <Setter TargetName="BottomTick"
                                    Property="Margin"
                                    Value="1,0,0,0"/>
                            <Setter TargetName="BottomTick"
                                    Property="ReservedSpace">
                                <Setter.Value>
                                    <Binding ElementName="SliderThumb" Path="ActualHeight"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Brush.BorderReadOnly}"/>
                            <Setter Property="Background"
                                    Value="{DynamicResource Brush.SurfaceDisabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
