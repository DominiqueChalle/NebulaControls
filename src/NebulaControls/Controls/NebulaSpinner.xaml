<!--
  Nom: NebulaSpinner
  Version: V1.02
  Description: Displays animated loading feedback for pending operations.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:NebulaControls.Controls">

    <Style x:Key="NebulaSpinner"
           TargetType="controls:NebulaSpinner">
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Brand}"/>
        <Setter Property="Background" Value="{DynamicResource Brush.Border}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:NebulaSpinner">
                    <Grid x:Name="SpinnerRoot"
                          Width="{TemplateBinding Width}"
                          Height="{TemplateBinding Height}"
                          RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <RotateTransform/>
                        </Grid.RenderTransform>
                        <Grid.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                         From="0"
                                                         To="360"
                                                         Duration="0:0:0.9"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Grid.Triggers>

                        <Ellipse Stroke="{TemplateBinding Background}"
                                 StrokeThickness="3"
                                 Opacity="0.35"/>

                        <Ellipse x:Name="SpinnerArc"
                                 Stroke="{TemplateBinding Foreground}"
                                 StrokeThickness="3"
                                 StrokeStartLineCap="Round"
                                 StrokeEndLineCap="Round"
                                 StrokeDashArray="2 4"/>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Brush.TextDisabled}"/>
                            <Setter Property="Background"
                                    Value="{DynamicResource Brush.BorderDisabled}"/>
                            <Setter TargetName="SpinnerArc"
                                    Property="Opacity"
                                    Value="0.6"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
