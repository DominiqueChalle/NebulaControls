<!--
  Nom: NebulaChip
  Version: V1.02
  Description: Displays removable or selectable compact filter tokens.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:NebulaControls.Controls">

    <Style x:Key="NebulaChipCloseButton"
           TargetType="Button">
        <Setter Property="Width" Value="20"/>
        <Setter Property="Height" Value="20"/>
        <Setter Property="Margin" Value="6,0,-3,0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=controls:NebulaChip}}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="10">
                        <TextBlock Text="&#xE711;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="8"
                                   Foreground="{TemplateBinding Foreground}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder"
                                    Property="Background"
                                    Value="{DynamicResource Brush.SurfaceHover}"/>
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder"
                                    Property="Background"
                                    Value="{DynamicResource Brush.SurfaceActive}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NebulaChip"
           BasedOn="{StaticResource Typography.Text.Primary}"
           TargetType="controls:NebulaChip">
        <Setter Property="Background" Value="{DynamicResource Brush.SurfaceActive}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="MinHeight" Value="30"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:NebulaChip">
                    <Border x:Name="ChipBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="15"
                            MinHeight="{TemplateBinding MinHeight}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <StackPanel Orientation="Horizontal">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                            <Button x:Name="CloseButton"
                                    Command="{Binding CloseCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                    Style="{StaticResource NebulaChipCloseButton}"
                                    Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsCloseVisible" Value="True">
                            <Setter TargetName="CloseButton"
                                    Property="Visibility"
                                    Value="Visible"/>
                        </Trigger>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ChipBorder"
                                    Property="Background"
                                    Value="{DynamicResource Brush.SurfaceHover}"/>
                            <Setter TargetName="ChipBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource Brush.BorderHover}"/>
                        </Trigger>

                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ChipBorder"
                                    Property="Background"
                                    Value="{DynamicResource Brush.BrandStrong}"/>
                            <Setter TargetName="ChipBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource Brush.Brand}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Brush.BrandSoft}"/>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ChipBorder"
                                    Property="Background"
                                    Value="{DynamicResource Brush.BackgroundDisabled}"/>
                            <Setter TargetName="ChipBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource Brush.BorderDisabled}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Brush.TextDisabled}"/>
                            <Setter Property="Cursor"
                                    Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NebulaBrandChip"
           BasedOn="{StaticResource NebulaChip}"
           TargetType="controls:NebulaChip">
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Brand}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.BrandSoft}"/>
    </Style>

    <Style x:Key="NebulaSuccessChip"
           BasedOn="{StaticResource NebulaChip}"
           TargetType="controls:NebulaChip">
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Success}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Success}"/>
    </Style>

    <Style x:Key="NebulaWarningChip"
           BasedOn="{StaticResource NebulaChip}"
           TargetType="controls:NebulaChip">
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Warning}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Warning}"/>
    </Style>

    <Style x:Key="NebulaDangerChip"
           BasedOn="{StaticResource NebulaChip}"
           TargetType="controls:NebulaChip">
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Danger}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Danger}"/>
    </Style>

    <Style BasedOn="{StaticResource NebulaChip}"
           TargetType="controls:NebulaChip"/>

</ResourceDictionary>
