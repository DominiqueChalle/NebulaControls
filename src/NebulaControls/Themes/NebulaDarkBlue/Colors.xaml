    <!-- ===================================================== -->
    <!-- Accent Colors                                         -->
    <!-- ===================================================== -->

    <Color x:Key="Color.Accent">
        #5F8FD6
    </Color>

    <Color x:Key="Color.AccentHover">
        #76A3E3
