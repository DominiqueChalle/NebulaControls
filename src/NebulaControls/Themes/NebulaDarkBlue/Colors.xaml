    <!-- States Colors                                         -->
    <!-- ===================================================== -->

    <Color x:Key="Color.Success">
        #2ECC71
    </Color>

    <Color x:Key="Color.Warning">
        #F5A623
    </Color>

    <Color x:Key="Color.Danger">
        #E74C3C
    </Color>

    <Color x:Key="Color.Info">
        #4A90E2
    </Color>

