<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===================================================== -->
    <!-- Backgrounds Colors                                    -->
    <!-- ===================================================== -->

    <Color x:Key="Color.Background">
        #1A1B1E
    </Color>

    <Color x:Key="Color.BackgroundDisabled">
        #202226
    </Color>

    <Color x:Key="Color.BackgroundReadOnly">
        #1F2024
    </Color>

    <!-- ===================================================== -->
    <!-- Surface Colors                                        -->
    <!-- ===================================================== -->

    <Color x:Key="Color.Surface">
        #25272B
    </Color>

    <Color x:Key="Color.SurfaceHover">
        #2E3137
    </Color>

    <Color x:Key="Color.SurfaceActive">
        #383C44
    </Color>

    <Color x:Key="Color.SurfaceDisabled">
        #212328
    </Color>

    <Color x:Key="Color.SurfaceReadOnly">
        #2A2C31
