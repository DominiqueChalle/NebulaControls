<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:NebulaUI.Controls">

    <Style x:Key="NebulaTabItem"
           BasedOn="{StaticResource Typography.Text.Primary}"
           TargetType="controls:NebulaTabItem">
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Padding" Value="13,9"/>
        <Setter Property="Margin" Value="0,0,0,0"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="MinWidth" Value="78"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:NebulaTabItem">
                    <Grid SnapsToDevicePixels="True">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="TabBorder"
                                    Property="Background"
                                    Value="{DynamicResource Brush.SurfaceHover}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Brush.TextPrimary}"/>
                        </Trigger>

                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="TabBorder"
                                    Property="Background"
                                    Value="{DynamicResource Brush.SurfaceActive}"/>
                            <Setter TargetName="TabBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource Brush.BrandSoft}"/>
                            <Setter TargetName="TabBorder"
                                    Property="CornerRadius"
                                    Value="7"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Brush.TextPrimary}"/>
                        </Trigger>

                        <Trigger Property="TabStripPlacement" Value="Left">
                            <Setter Property="Margin"
                                    Value="0,0,0,0"/>
                            <Setter Property="MinWidth"
                                    Value="88"/>
                            <Setter Property="HorizontalContentAlignment"
                                    Value="Left"/>
                            <Setter Property="Padding"
                                    Value="11,10"/>
                        </Trigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="TabStripPlacement" Value="Left"/>
                                <Condition Property="IsSelected" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="TabBorder"
                                    Property="CornerRadius"
                                    Value="7"/>
                            <Setter Property="Margin"
                                    Value="0,0,0,0"/>
                        </MultiTrigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Brush.TextDisabled}"/>
                            <Setter TargetName="TabBorder"
                                    Property="Background"
                                    Value="Transparent"/>
                            <Setter TargetName="TabBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource Brush.BorderDisabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NebulaTabControl"
           BasedOn="{StaticResource Typography.Text.Primary}"
           TargetType="controls:NebulaTabControl">
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="SelectedIndex" Value="0"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource NebulaTabItem}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:NebulaTabControl">
                    <Grid x:Name="Root"
                          SnapsToDevicePixels="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TabPanel x:Name="HeaderPanel"
                                  Grid.Row="0"
                                  Grid.Column="1"
                                  Margin="0"
                                  Panel.ZIndex="1"
                                  IsItemsHost="True"
                                  KeyboardNavigation.TabIndex="1"/>

                        <Border x:Name="ContentBorder"
                                Grid.Row="1"
                                Grid.Column="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              ContentSource="SelectedContent"
                                              Margin="14"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="TabStripPlacement" Value="Left">
                            <Setter TargetName="HeaderPanel"
                                    Property="Grid.Row"
                                    Value="1"/>
                            <Setter TargetName="HeaderPanel"
                                    Property="Grid.Column"
                                    Value="0"/>
                            <Setter TargetName="HeaderPanel"
                                    Property="Margin"
                                    Value="0"/>
                            <Setter TargetName="ContentBorder"
                                    Property="Grid.Row"
                                    Value="1"/>
                            <Setter TargetName="ContentBorder"
                                    Property="Grid.Column"
                                    Value="1"/>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Brush.TextDisabled}"/>
                            <Setter TargetName="ContentBorder"
                                    Property="Background"
                                    Value="{DynamicResource Brush.SurfaceDisabled}"/>
                            <Setter TargetName="ContentBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource Brush.BorderDisabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
